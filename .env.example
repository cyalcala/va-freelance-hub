# Turso (LibSQL/SQLite edge database)
# Get these from: https://turso.tech → your database → connect
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Trigger.dev (scheduled jobs)
# Get this from: https://trigger.dev → your project → API keys
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxxxx
# Project ID from: https://trigger.dev → your project → Settings
TRIGGER_PROJECT_ID=proj_xxxxxxxxxxxxxxxxxx

# Vercel ISR revalidation (generate any random string, e.g. openssl rand -hex 32)
ISR_SECRET=your-random-secret-string

# App URL (set to localhost for dev, your Vercel URL for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic Claude API (Phase 2 only — for influencer digest summaries)
# Get this from: https://console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx
