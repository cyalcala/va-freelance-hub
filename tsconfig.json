{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@va-hub/config": ["packages/config/index.ts"]
    }
  },
  "exclude": ["node_modules", "apps/web/.next", "packages/zig-parser"]
}
