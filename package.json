{
  "name": "va-freelance-hub",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "jobs"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/frontend dev",
    "build": "bun run --cwd apps/frontend build",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "trigger:dev": "bunx trigger.dev@4.4.3 dev --config jobs/trigger.config.ts",
    "trigger:deploy": "bunx trigger.dev@4.4.3 deploy --config jobs/trigger.config.ts",
    "save": "bun run scripts/save.ts",
    "restore": "bun run scripts/restore.ts",
    "resurrect": "bun run scripts/resurrect.ts",
    "audit": "bun run scripts/automation-audit.ts",
    "sync:framework": "bun run scripts/sync-framework.ts",
    "check-build": "bun run scripts/check-build.ts",
    "ux-audit": "bun run scripts/ux-audit.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/uuid": "^11.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@trigger.dev/sdk": "4.4.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fast-xml-parser": "^5.5.6",
    "uuid": "^13.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
