{
  "name": "va-freelance-hub",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "jobs"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "trigger:dev": "bunx trigger.dev@latest dev",
    "trigger:deploy": "bunx trigger.dev@latest deploy"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.4.0",
    "wrangler": "^3.57.1"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "@trigger.dev/sdk": "4.4.3",
    "fast-xml-parser": "^4.3.0"
  }
}
