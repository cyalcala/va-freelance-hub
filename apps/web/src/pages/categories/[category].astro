---
import Layout from '../../layouts/Layout.astro';
import { getDb, opportunities } from '@va-hub/db';
import { eq, desc, and, count, sql } from 'drizzle-orm';
import { OpportunityCard } from '@/components/opportunity-card';
import { JOB_CATEGORY_MAP } from '@/lib/categories';

export const prerender = false;

Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=60, s-maxage=300, stale-while-revalidate=600'
);

const { category } = Astro.params;

if (!category || !JOB_CATEGORY_MAP[category]) {
  return Astro.redirect('/');
}

const info = JOB_CATEGORY_MAP[category];
const PAGE_SIZE = 30;
const requestedPage = Number.parseInt(Astro.url.searchParams.get('page') || '1', 10);
const currentPage = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : 1;
const offset = (currentPage - 1) * PAGE_SIZE;

let categoryJobs = [];
let totalJobs = 0;

function buildPageUrl(page: number) {
  const params = new URLSearchParams();
  if (page > 1) params.set('page', String(page));
  const qs = params.toString();
  return qs ? `/categories/${category}?${qs}` : `/categories/${category}`;
}

try {
  const db = getDb(Astro.locals.runtime.env);
  const whereClause = and(
    eq(opportunities.isActive, true),
    eq(opportunities.category, category)
  );

  const [totalResult] = await db
    .select({ total: count() })
    .from(opportunities)
    .where(whereClause);

  totalJobs = totalResult?.total ?? 0;

  categoryJobs = await db
    .select()
    .from(opportunities)
    .where(whereClause)
    .orderBy(desc(sql`coalesce(${opportunities.postedAt}, ${opportunities.scrapedAt})`))
    .limit(PAGE_SIZE)
    .offset(offset);
} catch (e) {
  console.error("DB Error in category page:", e);
}

const totalPages = Math.max(1, Math.ceil(totalJobs / PAGE_SIZE));
const hasPrevious = currentPage > 1;
const hasNext = currentPage < totalPages;
const resultStart = totalJobs === 0 ? 0 : offset + 1;
const resultEnd = Math.min(offset + categoryJobs.length, totalJobs);
---

<Layout 
  title={`${info.title} Remote Jobs for Filipinos — VA & Freelance Hub`}
  description={`Browse and search all active ${info.title.toLowerCase()} remote jobs and virtual assistant opportunities open to Filipino talents. Updated automatically.`}
>
  <section class="w-full max-w-4xl mx-auto pt-10 md:pt-14">
    <div class="mb-8">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-ink/50 hover:text-accent transition-colors group mb-6"
      >
        <span class="inline-block transition-transform group-hover:-translate-x-0.5">&larr;</span>
        All categories
      </a>

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-overline text-accent mb-2">Category</p>
          <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-ink">
            {info.title}
          </h1>
          <p class="text-ink/55 text-[15px] max-w-xl mt-3 leading-relaxed">
            The latest active {info.title.toLowerCase()} roles open to Filipino
            remote workers.
          </p>
        </div>
        <span class="text-sm font-semibold text-ink/60 bg-surface border border-ink/[0.09] px-4 py-2 rounded-full self-start sm:self-auto shrink-0 tabular-nums">
          {totalJobs.toLocaleString()} {totalJobs === 1 ? 'job' : 'jobs'}
        </span>
      </div>
    </div>

    <div class="mb-4 flex flex-col sm:flex-row sm:items-center justify-between gap-2 text-[13px] font-semibold text-ink/45">
      <p class="tabular-nums">
        Showing {resultStart.toLocaleString()}–{resultEnd.toLocaleString()} of {totalJobs.toLocaleString()}
      </p>
      <a href={`/opportunities?category=${category}#search`} class="text-accent hover:text-accent-hover transition-colors">
        Search this category
      </a>
    </div>

    {categoryJobs.length === 0 ? (
      <div class="text-center py-24 bg-surface/60 rounded-2xl border border-ink/[0.07]">
        <p class="text-ink/55 font-semibold text-lg">No active openings here right now.</p>
        <p class="text-ink/40 text-sm mt-1">New roles arrive automatically throughout the day.</p>
        <a href="/opportunities" class="inline-flex items-center mt-5 px-4 py-2 rounded-full bg-ink/[0.05] hover:bg-accent-soft text-ink hover:text-accent font-semibold text-sm transition-colors">Browse all jobs</a>
      </div>
    ) : (
      <div class="bg-surface border border-ink/[0.07] rounded-2xl p-2 sm:p-3 shadow-card flex flex-col divide-y divide-ink/[0.05]">
        {categoryJobs.map((opp) => (
          <OpportunityCard opportunity={opp} />
        ))}
      </div>
    )}

    <nav class="mt-8 flex items-center justify-between gap-4" aria-label={`${info.title} pagination`}>
      {hasPrevious ? (
        <a
          href={buildPageUrl(currentPage - 1)}
          class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-surface border border-ink/[0.09] text-sm font-semibold text-ink/70 hover:text-accent hover:border-accent/30 transition-colors"
        >
          &larr; Previous
        </a>
      ) : (
        <span class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-ink/[0.03] border border-ink/[0.05] text-sm font-semibold text-ink/25">
          &larr; Previous
        </span>
      )}

      <span class="text-[13px] font-semibold text-ink/45 tabular-nums">
        Page {currentPage.toLocaleString()} of {totalPages.toLocaleString()}
      </span>

      {hasNext ? (
        <a
          href={buildPageUrl(currentPage + 1)}
          class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-surface border border-ink/[0.09] text-sm font-semibold text-ink/70 hover:text-accent hover:border-accent/30 transition-colors"
        >
          Next &rarr;
        </a>
      ) : (
        <span class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-ink/[0.03] border border-ink/[0.05] text-sm font-semibold text-ink/25">
          Next &rarr;
        </span>
      )}
    </nav>
  </section>
</Layout>
