---
import Layout from '../layouts/Layout.astro';
import { getDb, opportunities } from '@va-hub/db';
import { eq, desc } from 'drizzle-orm';
import { OpportunityCard } from '@/components/opportunity-card';

export const prerender = false;

let items = [];

try {
  const db = getDb(Astro.locals.runtime.env);
  items = await db
    .select()
    .from(opportunities)
    .where(eq(opportunities.isActive, true))
    .orderBy(desc(opportunities.scrapedAt))
    .limit(100);
} catch (e) {
  console.error("DB error:", e);
}
---

<Layout 
  title="Opportunities — Remote PH"
  description="Browse all remote freelance and VA job opportunities for Filipinos."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight mb-2">Opportunities</h1>
      <p class="text-zinc-400 text-sm">
        {items.length} active listings • auto-updated twice daily
      </p>
    </div>

    {items.length === 0 ? (
      <div class="border border-border rounded-xl p-16 text-center text-zinc-500 text-sm">
        No opportunities yet. Check back soon — the scraper runs twice daily.
      </div>
    ) : (
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((opp) => (
          <OpportunityCard key={opp.id} opportunity={opp} client:load />
        ))}
      </div>
    )}
  </div>
</Layout>
