---
import Layout from '../layouts/Layout.astro';
import { getDb, opportunities } from '@va-hub/db';
import { and, asc, count, desc, eq, like, or, type SQL, sql } from 'drizzle-orm';
import { OpportunityCard } from '@/components/opportunity-card';
import { JOB_CATEGORY_MAP } from '@/lib/categories';

export const prerender = false;

Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=60, s-maxage=300, stale-while-revalidate=600'
);

const PAGE_SIZE = 30;
const TYPE_OPTIONS = ['VA', 'freelance', 'project', 'full-time', 'part-time'];

const searchParams = Astro.url.searchParams;
const query = (searchParams.get('q') || '').trim();
const category = searchParams.get('category') || '';
const type = searchParams.get('type') || '';
const platform = searchParams.get('platform') || '';
const requestedPage = Number.parseInt(searchParams.get('page') || '1', 10);
const currentPage = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : 1;
const offset = (currentPage - 1) * PAGE_SIZE;

let pageJobs = [];
let platformOptions: string[] = [];
let totalJobs = 0;

function buildPageUrl(page: number) {
  const params = new URLSearchParams();
  if (query) params.set('q', query);
  if (category) params.set('category', category);
  if (type) params.set('type', type);
  if (platform) params.set('platform', platform);
  if (page > 1) params.set('page', String(page));
  const qs = params.toString();
  return qs ? `/opportunities?${qs}` : '/opportunities';
}

try {
  const db = getDb(Astro.locals.runtime.env);
  const filters: SQL[] = [eq(opportunities.isActive, true)];

  if (category && JOB_CATEGORY_MAP[category]) {
    filters.push(eq(opportunities.category, category));
  }

  if (type && TYPE_OPTIONS.includes(type)) {
    filters.push(eq(opportunities.type, type));
  }

  if (platform) {
    filters.push(eq(opportunities.sourcePlatform, platform));
  }

  if (query) {
    const term = `%${query}%`;
    filters.push(
      or(
        like(opportunities.title, term),
        like(opportunities.company, term),
        like(opportunities.sourcePlatform, term)
      )
    );
  }

  const whereClause = and(...filters);

  const [totalResult] = await db
    .select({ total: count() })
    .from(opportunities)
    .where(whereClause);

  totalJobs = totalResult?.total ?? 0;

  pageJobs = await db
    .select()
    .from(opportunities)
    .where(whereClause)
    .orderBy(desc(sql`coalesce(${opportunities.postedAt}, ${opportunities.scrapedAt})`))
    .limit(PAGE_SIZE)
    .offset(offset);

  const platforms = await db
    .select({ name: opportunities.sourcePlatform })
    .from(opportunities)
    .where(eq(opportunities.isActive, true))
    .groupBy(opportunities.sourcePlatform)
    .orderBy(asc(opportunities.sourcePlatform));

  platformOptions = platforms.map((item) => item.name).filter(Boolean);
} catch (e) {
  console.error('DB Error in opportunities page:', e);
}

const totalPages = Math.max(1, Math.ceil(totalJobs / PAGE_SIZE));
const hasPrevious = currentPage > 1;
const hasNext = currentPage < totalPages;
const resultStart = totalJobs === 0 ? 0 : offset + 1;
const resultEnd = Math.min(offset + pageJobs.length, totalJobs);
---

<Layout
  title="Browse Remote Jobs for Filipinos — VA & Freelance Hub"
  description="Search and filter every active remote and VA role open to Filipino talent. Updated automatically, all day."
>
  <section class="w-full max-w-5xl mx-auto pt-10 md:pt-14">
    <div class="mb-8">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-ink/50 hover:text-accent transition-colors group mb-6"
      >
        <span class="inline-block transition-transform group-hover:-translate-x-0.5">&larr;</span>
        Home
      </a>

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-overline text-accent mb-2">The full board</p>
          <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-ink">
            Every open remote role
          </h1>
          <p class="text-ink/55 text-[15px] max-w-xl mt-3 leading-relaxed">
            Search, filter, and page through every active opportunity open to
            Filipino remote workers.
          </p>
        </div>
        <div class="text-sm font-semibold text-ink/60 bg-surface border border-ink/[0.09] px-4 py-2 rounded-full self-start sm:self-auto shrink-0 tabular-nums">
          {totalJobs.toLocaleString()} {totalJobs === 1 ? 'job' : 'jobs'}
        </div>
      </div>
    </div>

    <form
      id="search"
      method="get"
      action="/opportunities"
      class="scroll-mt-20 sticky top-[4.5rem] z-40 mt-8 mb-8 bg-parchment/85 backdrop-blur-xl border border-ink/[0.08] rounded-2xl p-2.5 shadow-soft"
    >
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.6fr)_repeat(3,minmax(0,0.8fr))_auto] gap-2">
        <label class="sr-only" for="q">Search jobs</label>
        <input
          id="q"
          type="search"
          name="q"
          value={query}
          placeholder="Search roles, companies, or platforms…"
          class="w-full h-12 px-4 bg-surface border border-ink/[0.09] rounded-xl text-ink font-medium focus:outline-none focus:border-accent/50 focus:ring-4 focus:ring-accent/10 transition-all placeholder:text-ink/35"
        />

        <label class="sr-only" for="category">Category</label>
        <select
          id="category"
          name="category"
          class="w-full h-12 px-3 bg-surface border border-ink/[0.09] rounded-xl text-sm text-ink font-medium focus:outline-none focus:border-accent/50 focus:ring-4 focus:ring-accent/10"
        >
          <option value="">All categories</option>
          {Object.entries(JOB_CATEGORY_MAP).map(([key, info]) => (
            <option value={key} selected={category === key}>{info.title}</option>
          ))}
        </select>

        <label class="sr-only" for="type">Type</label>
        <select
          id="type"
          name="type"
          class="w-full h-12 px-3 bg-surface border border-ink/[0.09] rounded-xl text-sm text-ink font-medium focus:outline-none focus:border-accent/50 focus:ring-4 focus:ring-accent/10"
        >
          <option value="">All types</option>
          {TYPE_OPTIONS.map((option) => (
            <option value={option} selected={type === option}>{option}</option>
          ))}
        </select>

        <label class="sr-only" for="platform">Platform</label>
        <select
          id="platform"
          name="platform"
          class="w-full h-12 px-3 bg-surface border border-ink/[0.09] rounded-xl text-sm text-ink font-medium focus:outline-none focus:border-accent/50 focus:ring-4 focus:ring-accent/10"
        >
          <option value="">All platforms</option>
          {platformOptions.map((option) => (
            <option value={option} selected={platform === option}>{option}</option>
          ))}
        </select>

        <button
          type="submit"
          class="h-12 bg-accent hover:bg-accent-hover text-white px-6 rounded-xl text-sm font-semibold transition-all shadow-soft hover:shadow-lift active:scale-[0.98]"
        >
          Search
        </button>
      </div>
    </form>

    <div class="mb-4 flex flex-col sm:flex-row sm:items-center justify-between gap-2 text-[13px] font-semibold text-ink/45">
      <p class="tabular-nums">
        Showing {resultStart.toLocaleString()}–{resultEnd.toLocaleString()} of {totalJobs.toLocaleString()}
      </p>
      {(query || category || type || platform) && (
        <a href="/opportunities" class="text-accent hover:text-accent-hover transition-colors">
          Clear filters
        </a>
      )}
    </div>

    {pageJobs.length === 0 ? (
      <div class="text-center py-24 bg-surface/60 rounded-2xl border border-ink/[0.07]">
        <p class="text-ink/55 font-semibold text-lg">No jobs match these filters.</p>
        <p class="text-ink/40 text-sm mt-1">Try removing a filter or broadening your search.</p>
        <a href="/opportunities" class="inline-flex items-center mt-5 px-4 py-2 rounded-full bg-ink/[0.05] hover:bg-accent-soft text-ink hover:text-accent font-semibold text-sm transition-colors">Reset filters</a>
      </div>
    ) : (
      <div class="bg-surface border border-ink/[0.07] rounded-2xl p-2 sm:p-3 shadow-card flex flex-col divide-y divide-ink/[0.05]">
        {pageJobs.map((opp) => (
          <OpportunityCard opportunity={opp} />
        ))}
      </div>
    )}

    <nav class="mt-8 flex items-center justify-between gap-4" aria-label="Opportunity pagination">
      {hasPrevious ? (
        <a
          href={buildPageUrl(currentPage - 1)}
          class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-surface border border-ink/[0.09] text-sm font-semibold text-ink/70 hover:text-accent hover:border-accent/30 transition-colors"
        >
          &larr; Previous
        </a>
      ) : (
        <span class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-ink/[0.03] border border-ink/[0.05] text-sm font-semibold text-ink/25">
          &larr; Previous
        </span>
      )}

      <span class="text-[13px] font-semibold text-ink/45 tabular-nums">
        Page {currentPage.toLocaleString()} of {totalPages.toLocaleString()}
      </span>

      {hasNext ? (
        <a
          href={buildPageUrl(currentPage + 1)}
          class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-surface border border-ink/[0.09] text-sm font-semibold text-ink/70 hover:text-accent hover:border-accent/30 transition-colors"
        >
          Next &rarr;
        </a>
      ) : (
        <span class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-ink/[0.03] border border-ink/[0.05] text-sm font-semibold text-ink/25">
          Next &rarr;
        </span>
      )}
    </nav>
  </section>
</Layout>
