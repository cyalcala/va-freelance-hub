---
import Layout from '../layouts/Layout.astro';
import { getDb, vaDirectory } from '@va-hub/db';
import { DirectorySearch } from '@/components/DirectorySearch';
import { asc, eq } from 'drizzle-orm';

export const prerender = false;

Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=60, s-maxage=300, stale-while-revalidate=600'
);

let allAgencies: any[] = [];

try {
  const db = getDb(Astro.locals.runtime.env);
  // Only select the fields used by DirectorySearch/CategoryCard to keep
  // the hydration payload small. Drops notes, hiringPageUrl, verifiedAt,
  // createdAt, rating, atsToken, atsPlatform, and hiresFilipinos.
  allAgencies = await db
    .select({
      id: vaDirectory.id,
      companyName: vaDirectory.companyName,
      website: vaDirectory.website,
      niche: vaDirectory.niche,
      isDayshift: vaDirectory.isDayshift,
      isVerified: vaDirectory.isVerified,
      isRemote: vaDirectory.isRemote,
      isMarketplace: vaDirectory.isMarketplace,
    })
    .from(vaDirectory)
    // Directory audit (2026-07): hides companies flagged hires_filipinos=0
    // (defunct, duplicates, or verified not-Filipino-hiring). Reversible —
    // flip the flag to restore. See migration 0024.
    .where(eq(vaDirectory.hiresFilipinos, true))
    .orderBy(asc(vaDirectory.companyName));
} catch (e) {
  console.error("DB error:", e);
}
---

<Layout
  title="Agencies & Companies That Hire Filipinos — VA & Freelance Hub"
  description="A curated, vetted directory of VA agencies and remote-first companies that actively hire Filipino talent."
>
  <div class="max-w-5xl mx-auto pt-12 md:pt-16">
    <div class="mb-10 max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-overline text-accent mb-2">The directory</p>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-ink">
        Companies that hire Filipinos
      </h1>
      <p class="mt-3 text-[15px] sm:text-base text-ink/55 leading-relaxed">
        A vetted list of VA agencies and remote-first companies known to hire
        in the Philippines — from dayshift agencies to global tech teams.
      </p>
    </div>

    <DirectorySearch client:load directory={allAgencies} />
  </div>
</Layout>
