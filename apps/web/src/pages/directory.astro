---
import Layout from '../layouts/Layout.astro';
import { getDb, vaDirectory } from '@va-hub/db';
import { DirectorySearch } from '@/components/DirectorySearch';
import { asc } from 'drizzle-orm';

export const prerender = false;

Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=60, s-maxage=300, stale-while-revalidate=600'
);

let allAgencies: any[] = [];

try {
  const db = getDb(Astro.locals.runtime.env);
  // Only select the fields used by DirectorySearch/CategoryCard to keep
  // the hydration payload small. Drops notes, hiringPageUrl, verifiedAt,
  // createdAt, rating, atsToken, atsPlatform, and hiresFilipinos.
  allAgencies = await db
    .select({
      id: vaDirectory.id,
      companyName: vaDirectory.companyName,
      website: vaDirectory.website,
      niche: vaDirectory.niche,
      isDayshift: vaDirectory.isDayshift,
      isVerified: vaDirectory.isVerified,
      isRemote: vaDirectory.isRemote,
      isMarketplace: vaDirectory.isMarketplace,
    })
    .from(vaDirectory)
    .orderBy(asc(vaDirectory.companyName));
} catch (e) {
  console.error("DB error:", e);
}
---

<Layout 
  title="VA Agencies & Companies — Remote Jobs for Filipinos"
  description="A curated directory of VA agencies and remote companies that hire Filipino talents."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="mb-12 text-center max-w-2xl mx-auto animate-in slide-in-from-bottom-8 fade-in duration-1000 ease-out fill-mode-both">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tighter mb-4 text-ink">
        Find an <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-hover">Agency Job</span>
      </h1>
      <p class="text-ink/60 text-lg font-medium leading-relaxed">
        Browse our curated directory of legitimate Virtual Assistant agencies and companies specifically hiring in the Philippines.
      </p>
    </div>

    <div class="animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-300 fill-mode-both">
      <DirectorySearch client:load directory={allAgencies} />
    </div>
  </div>
</Layout>
