---
import Layout from '../layouts/Layout.astro';
import { getDb, opportunities, vaDirectory } from '@va-hub/db';
import { eq, desc, count, sql, inArray } from 'drizzle-orm';
import { OpportunitySearch } from '@/components/OpportunitySearch';

export const prerender = false;

Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=60, s-maxage=300, stale-while-revalidate=600'
);

// How many freshest jobs to preview per category on the homepage.
const PER_CATEGORY_PREVIEW = 6;

let stats = { opportunities: 0, companies: 0 };
let latestOpportunities: any[] = [];
let categoryTotals: Record<string, number> = {};

try {
  const db = getDb(Astro.locals.runtime.env);

  const [oppCount] = await db.select({ count: count() }).from(opportunities).where(eq(opportunities.isActive, true));
  const [dirCount] = await db.select({ count: count() }).from(vaDirectory);

  stats = { opportunities: oppCount?.count ?? 0, companies: dirCount?.count ?? 0 };

  // Homepage preview is "Fresh opportunities BY CATEGORY". Previously this
  // fetched a single flat "latest 60 overall" pool, so whenever ingestion
  // skewed toward a few categories (e.g. a batch of tech ATS sources), whole
  // categories with hundreds of active jobs — customer-service, design —
  // dropped off the homepage entirely because none appeared in the latest 60.
  // Fix the root cause: fetch the freshest N *per category* so every category
  // that has jobs always gets a card. A window function keeps this to one
  // round-trip; then a typed fetch preserves the slim projection + JSON tag
  // parsing + ordering.
  const idRows = await db.all<{ id: number }>(sql`
    SELECT id FROM (
      SELECT id, ROW_NUMBER() OVER (
        PARTITION BY category ORDER BY coalesce(posted_at, scraped_at) DESC
      ) AS rn
      FROM opportunities WHERE is_active = 1
    ) WHERE rn <= ${PER_CATEGORY_PREVIEW}
  `);
  const ids = idRows.map((r) => Number(r.id)).filter((n) => Number.isFinite(n));

  // Only select the fields used by OpportunityCard/OpportunitySearch to keep
  // the hydration payload small (excludes description, hashes, timestamps,
  // clickCount, payRange, etc.).
  latestOpportunities = ids.length
    ? await db
        .select({
          id: opportunities.id,
          title: opportunities.title,
          company: opportunities.company,
          type: opportunities.type,
          sourceUrl: opportunities.sourceUrl,
          sourcePlatform: opportunities.sourcePlatform,
          tags: opportunities.tags,
          category: opportunities.category,
          experienceLevel: opportunities.experienceLevel,
          postedAt: opportunities.postedAt,
        })
        .from(opportunities)
        .where(inArray(opportunities.id, ids))
        .orderBy(desc(sql`coalesce(${opportunities.postedAt}, ${opportunities.scrapedAt})`))
    : [];

  // True per-category active totals so each card's "See all N jobs" reflects
  // the real category size (matching its /categories/[slug] page), not the
  // preview subset.
  const totalRows = await db
    .select({ category: opportunities.category, n: count() })
    .from(opportunities)
    .where(eq(opportunities.isActive, true))
    .groupBy(opportunities.category);
  categoryTotals = Object.fromEntries(totalRows.map((r) => [r.category, r.n]));
} catch (e) {
  console.error("DB error:", e);
}
---

<Layout 
  title="VA Freelance Hub — Remote Jobs for Filipinos"
  description="Self-updating directory of remote job opportunities and VA-friendly companies that hire Filipinos. Updated every 30 minutes automatically."
>
  <div class="mb-24 text-center max-w-4xl mx-auto pt-8 md:pt-16 animate-in slide-in-from-bottom-8 fade-in duration-1000 ease-out fill-mode-both">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/5 text-accent text-xs sm:text-sm font-bold tracking-widest uppercase mb-10 shadow-sm hover:shadow-md transition-shadow">
      <span class="w-2 h-2 rounded-full bg-accent animate-pulse shadow-[0_0_8px_rgba(224,93,58,0.6)]"></span>
      Auto-updates twice daily
    </div>
    <h2 class="text-3xl sm:text-5xl md:text-7xl font-extrabold tracking-tighter mb-8 leading-[1.1] text-ink drop-shadow-sm break-words">
      Premium Remote Jobs for <br class="hidden sm:block" />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent via-[#ff784f] to-accent-hover italic pr-2">Filipino Talents</span>
    </h2>
    <p class="text-ink/60 text-lg sm:text-xl max-w-2xl mx-auto font-medium leading-relaxed">
      A self-updating directory of VA and freelance opportunities — curated
      from the best remote job boards and refreshed automatically.
    </p>
    
    <div class="flex gap-16 justify-center mt-16 mb-12 animate-in fade-in zoom-in-95 duration-1000 delay-300 fill-mode-both">
      <div class="text-center group cursor-default">
        <div class="text-6xl font-black text-transparent bg-clip-text bg-gradient-to-br from-ink to-ink/60 group-hover:from-accent group-hover:to-accent-hover transition-all duration-300 transform group-hover:scale-105">{stats.opportunities.toLocaleString()}</div>
        <div class="text-xs text-ink/50 mt-3 font-extrabold tracking-widest uppercase">Active Opportunities</div>
      </div>
      <div class="text-center group cursor-default">
        <div class="text-6xl font-black text-transparent bg-clip-text bg-gradient-to-br from-ink to-ink/60 group-hover:from-accent group-hover:to-accent-hover transition-all duration-300 transform group-hover:scale-105">{stats.companies.toLocaleString()}</div>
        <div class="text-xs text-ink/50 mt-3 font-extrabold tracking-widest uppercase">VA-Friendly Companies</div>
      </div>
    </div>
  </div>

  <div class="animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-500 fill-mode-both">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <p class="text-xs font-black uppercase tracking-widest text-accent mb-2">Latest preview</p>
        <h3 class="text-2xl sm:text-3xl font-black tracking-tight text-ink">Fresh opportunities by category</h3>
        <p class="text-sm text-ink/50 font-medium mt-2 max-w-2xl">
          Showing a compact preview of the newest roles. Use the full board for search, filters, and pagination.
        </p>
      </div>
      <a
        href="/opportunities"
        class="inline-flex items-center justify-center bg-accent hover:bg-accent-hover text-white px-5 py-3 rounded-full text-xs font-black uppercase tracking-widest transition-all shadow-sm hover:shadow-accent/20"
      >
        Browse all jobs
      </a>
    </div>
    <OpportunitySearch client:load opportunities={latestOpportunities} categoryTotals={categoryTotals} showSearch={false} />
  </div>
</Layout>
