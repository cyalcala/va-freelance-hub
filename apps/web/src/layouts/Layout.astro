---
import '../styles/globals.css';
import { Footer } from '@/components/footer';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const path = Astro.url.pathname;
const isActive = (base: string) =>
  base === '/' ? path === '/' : path.startsWith(base);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FBFAF7" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://remotejobs-ph.pages.dev/og-image.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://remotejobs-ph.pages.dev/og-image.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-parchment text-ink antialiased selection:bg-accent/20 selection:text-ink flex flex-col">

    <!-- Subtle warm depth: one restrained radial, not competing color blobs. -->
    <div class="fixed inset-0 -z-10 pointer-events-none overflow-hidden">
      <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[80rem] h-[40rem] rounded-full bg-accent/[0.06] blur-[140px]"></div>
    </div>

    <!-- Slim, single-row glass header. -->
    <header class="sticky top-0 z-50 w-full border-b border-ink/[0.07] bg-parchment/80 backdrop-blur-xl">
      <div class="max-w-[80rem] mx-auto w-full px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2.5 group shrink-0" aria-label="RemotePH home">
          <span class="grid place-items-center w-9 h-9 rounded-xl bg-ink text-parchment font-extrabold text-lg tracking-tight transition-transform duration-300 ease-out-soft group-hover:scale-105">R</span>
          <span class="text-[1.35rem] font-extrabold tracking-tight text-ink leading-none">
            Remote<span class="text-accent">PH</span>
          </span>
        </a>

        <nav class="flex items-center gap-1 sm:gap-2">
          <a href="/opportunities"
             class={`hidden sm:inline-flex items-center px-3.5 py-2 rounded-full text-sm font-semibold transition-colors ${isActive('/opportunities') || isActive('/categories') ? 'text-ink bg-ink/[0.06]' : 'text-ink/60 hover:text-ink hover:bg-ink/[0.04]'}`}>
            Jobs
          </a>
          <a href="/directory"
             class={`hidden sm:inline-flex items-center px-3.5 py-2 rounded-full text-sm font-semibold transition-colors ${isActive('/directory') ? 'text-ink bg-ink/[0.06]' : 'text-ink/60 hover:text-ink hover:bg-ink/[0.04]'}`}>
            Agencies
          </a>
          <a href="/opportunities"
             class="inline-flex items-center gap-1.5 bg-accent hover:bg-accent-hover text-white pl-4 pr-4 py-2 rounded-full text-sm font-semibold shadow-soft transition-all duration-200 ease-out-soft hover:shadow-lift active:scale-[0.97]">
            Browse jobs
          </a>
        </nav>
      </div>
    </header>

    <div class="max-w-[80rem] mx-auto w-full px-4 sm:px-6 lg:px-8 flex-1">
      <main class="w-full pb-24 md:pb-16">
        <slot />
      </main>
    </div>

    <div class="mt-auto border-t border-ink/[0.07]">
      <div class="max-w-[80rem] mx-auto px-4 sm:px-6 lg:px-8">
        <Footer />
      </div>
    </div>

    <!-- Mobile bottom tab bar: thumb-reachable primary nav, safe-area aware. -->
    <nav class="md:hidden fixed bottom-0 inset-x-0 z-50 border-t border-ink/[0.08] bg-parchment/90 backdrop-blur-xl"
         style="padding-bottom: var(--safe-bottom);" aria-label="Primary">
      <div class="grid grid-cols-3 max-w-lg mx-auto">
        <a href="/" class={`flex flex-col items-center justify-center gap-1 py-2.5 text-[11px] font-semibold transition-colors ${isActive('/') ? 'text-accent' : 'text-ink/50'}`}>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/></svg>
          Home
        </a>
        <a href="/opportunities" class={`flex flex-col items-center justify-center gap-1 py-2.5 text-[11px] font-semibold transition-colors ${isActive('/opportunities') || isActive('/categories') ? 'text-accent' : 'text-ink/50'}`}>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
          Jobs
        </a>
        <a href="/directory" class={`flex flex-col items-center justify-center gap-1 py-2.5 text-[11px] font-semibold transition-colors ${isActive('/directory') ? 'text-accent' : 'text-ink/50'}`}>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 9h.01M9 13h.01M9 17h.01M15 9h.01M15 13h.01M15 17h.01"/></svg>
          Agencies
        </a>
      </div>
    </nav>
  </body>
</html>
