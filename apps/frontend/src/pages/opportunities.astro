---
import Layout from '../layouts/Layout.astro';
import { db } from '@va-hub/db/client';
import { opportunities as opportunitiesTable } from '@va-hub/db/schema';
import { desc } from 'drizzle-orm';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'max-age=0, s-maxage=60, stale-while-revalidate=59');

let liveOpportunities = [];
try {
  liveOpportunities = await db.select()
    .from(opportunitiesTable)
    .orderBy(desc(opportunitiesTable.scrapedAt))
    .limit(800); 
} catch (e) {
  console.error(e);
}

function formatRelativeTime(dateInput: Date | null) {
  if (!dateInput) return 'Today';
  const now = new Date();
  const date = new Date(dateInput);
  const diffHours = Math.floor((now.getTime() - date.getTime()) / (1000 * 60 * 60));
  if (diffHours < 1) return 'Just Now';
  if (diffHours < 24) return `${diffHours}h ago`;
  const diffDays = Math.floor(diffHours / 24);
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays}d ago`;
  return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
}

function getRelevanceScore(opp: any) {
  const text = `${opp.title} ${opp.company} ${opp.description || ''}`.toLowerCase();
  
  // 1. FRESHNESS (The ultimate decider)
  const now = Date.now();
  const scrapedAt = new Date(opp.scrapedAt).getTime();
  const hoursOld = (now - scrapedAt) / (1000 * 60 * 60);
  
  let score = 0;
  if (hoursOld < 4) score += 1000000; // Unshakable "Just Now" status
  else if (hoursOld < 12) score += 500000;
  else if (hoursOld < 24) score += 100000;

  // 2. RELEVANCY (Secondary tie-breaker)
  const isVaFriendly = ["assistant", "va", "customer", "support", "admin", "bookkeeping", "filipino", "philippines", "pinoy"].some(k => text.includes(k));
  const isSenior = ["senior", "vp", "director", "lead", "principal", "head"].some(k => text.includes(k));
  const isTech = ["engineer", "developer", "devops", "software", "backend", "frontend", "architect"].some(k => text.includes(k));

  if (isVaFriendly) score += 50000;
  if (isSenior) score -= 20000;
  if (isTech && !isVaFriendly) score -= 10000;

  return { score, isVaFriendly };
}

const scored = liveOpportunities.map(opp => {
  const meta = getRelevanceScore(opp);
  return { ...opp, relevancyScore: meta.score, isVaFriendly: meta.isVaFriendly };
}).sort((a, b) => {
  if (b.relevancyScore !== a.relevancyScore) return b.relevancyScore - a.relevancyScore;
  return new Date(b.scrapedAt).getTime() - new Date(a.scrapedAt).getTime();
});

// Diversity Pass (Demote, don't delete)
const companyCount = new Map();
const topTier = [];
const bottomTier = [];

for (const opp of scored) {
  const company = (opp.company || 'Unknown').toLowerCase().trim();
  const count = companyCount.get(company) || 0;
  const limit = opp.isVaFriendly ? 3 : 1;
  if (count < limit) {
    topTier.push(opp);
    companyCount.set(company, count + 1);
  } else {
    bottomTier.push(opp);
  }
}

const opportunities = [...topTier, ...bottomTier].slice(0, 200).map(opp => {
  const latestDate = new Date(Math.max(new Date(opp.postedAt || 0).getTime(), new Date(opp.scrapedAt).getTime()));
  const ageHours = (Date.now() - latestDate.getTime()) / (1000 * 60 * 60);
  return {
    ...opp,
    dateLabel: formatRelativeTime(latestDate),
    ageHours
  };
});
---

<Layout title="Feed | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-12">
      <div class="flex items-center gap-2 mb-4">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blueberry-500 tracking-[0.2em] uppercase">SIGNAL_ACTIVE</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-black text-blueberry-900 tracking-tighter mb-4 uppercase">Latest Openings</h1>
      <div class="flex flex-col md:flex-row md:items-center gap-4 mt-8">
        <input 
          type="text" 
          id="oppSearch" 
          placeholder="Search by title, company, or keywords..." 
          class="bg-white border border-blueberry-800/10 rounded-2xl px-6 py-4 text-sm w-full md:max-w-md focus:outline-none focus:border-blueberry-500/40 shadow-sm font-medium"
        />
        <div class="flex p-1 bg-white border border-blueberry-800/10 rounded-2xl shadow-sm self-start" id="oppFilters">
          <button data-age="all" class="time-btn active">All</button>
          <button data-age="24" class="time-btn text-emerald-600">24h</button>
          <button data-age="72" class="time-btn">3d</button>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 gap-3" id="oppsGrid">
      {opportunities.map((opp) => (
        <a 
          href={opp.sourceUrl} 
          target="_blank" 
          class="opp-card flex items-center justify-between p-5 rounded-[24px] bg-white border border-blueberry-800/10 hover:border-blueberry-500/20 hover:shadow-md transition-all active:scale-[0.99] group"
          data-search={`${opp.title} ${opp.company}`.toLowerCase()}
          data-age={opp.ageHours}
        >
          <div class="flex items-center gap-6">
            <div class="w-16 flex flex-col items-center">
              <span class="text-[10px] font-black text-blueberry-800/40 uppercase tracking-tighter">{opp.dateLabel}</span>
              {opp.ageHours < 24 && <span class="text-[8px] font-black text-emerald-600 uppercase mt-1">New</span>}
            </div>
            <div class="h-8 w-[1px] bg-blueberry-800/5"></div>
            <div>
              <div class="text-[14px] font-black text-blueberry-900 uppercase tracking-tight group-hover:text-blueberry-600 transition-colors leading-tight mb-0.5">{opp.title}</div>
              <div class="text-[10px] text-blueberry-800/60 font-bold uppercase tracking-widest">{opp.company}</div>
            </div>
          </div>
          <div class="flex items-center gap-4 text-blueberry-800/20">
             <span class="text-[9px] font-black uppercase tracking-widest hidden sm:block">{opp.sourcePlatform}</span>
             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 group-hover:opacity-100 group-hover:text-blueberry-500 transition-all"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
          </div>
        </a>
      ))}
    </div>

    <div id="oppsEmpty" class="hidden py-32 text-center text-blueberry-800/40 font-medium italic">No matches found.</div>
  </main>
</Layout>

<script is:inline>
  (function() {
    let q = "";
    let age = "all";

    function refresh() {
      const grid = document.getElementById('oppsGrid');
      const empty = document.getElementById('oppsEmpty');
      if (!grid) return;
      
      const items = grid.querySelectorAll('.opp-card');
      let count = 0;
      items.forEach(el => {
        const text = el.dataset.search || "";
        const hours = parseFloat(el.dataset.age || "999");
        const match = text.includes(q) && (age === "all" || hours <= parseFloat(age));
        el.style.display = match ? 'flex' : 'none';
        if (match) count++;
      });
      if (empty) empty.style.display = count > 0 ? 'none' : 'block';
    }

    // Single-entry delegation (Safe)
    if (!window.__FEED_INIT) {
      document.addEventListener('input', (e) => {
        if (e.target.id === 'oppSearch') {
          q = e.target.value.toLowerCase().trim();
          refresh();
        }
      });

      document.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-age]');
        if (btn && btn.closest('#oppFilters')) {
          const btns = btn.closest('#oppFilters').querySelectorAll('.time-btn');
          btns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          age = btn.dataset.age;
          refresh();
        }
      });
      window.__FEED_INIT = true;
    }

    document.addEventListener('astro:page-load', refresh);
    refresh();
  })();
</script>

<style>
  .time-btn {
    @apply px-5 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all cursor-pointer text-blueberry-800/40 hover:text-blueberry-900;
  }
  .time-btn.active {
    @apply bg-blueberry-50 text-blueberry-900 border border-blueberry-800/10 shadow-sm;
  }
</style>
