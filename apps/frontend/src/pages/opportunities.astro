---
import Layout from '../layouts/Layout.astro';
import { db } from '@va-hub/db/client';
import { opportunities as opportunitiesTable } from '@va-hub/db/schema';
import { desc } from 'drizzle-orm';

// Fetch live opportunities
let liveOpportunities = [];
let dbError = null;

try {
  liveOpportunities = await db.select()
    .from(opportunitiesTable)
    .orderBy(desc(opportunitiesTable.postedAt))
    .limit(100);
} catch (e) {
  console.error("Database fetch failed:", e);
  dbError = e.message;
}

const opportunities = liveOpportunities.map((opp) => ({
  title: opp.title,
  company: opp.company || 'Direct Hire',
  date: opp.postedAt ? new Date(opp.postedAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric' }) : 'Today',
  url: opp.sourceUrl,
  source: opp.sourcePlatform || 'Web',
}));
---

<Layout title="Opportunities | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-12">
      <div class="flex items-center gap-2 mb-4">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blue-500 tracking-[0.2em] uppercase">LIVE OPPORTUNITIES</span>
      </div>
      <h1 class="text-4xl font-extrabold text-white tracking-tighter mb-4">Latest Roles</h1>
      <p class="text-zinc-500 max-w-xl text-sm leading-relaxed">
        Fresh hiring signals captured from Reddit, Brave, and curated boards.
      </p>
    </header>

    {dbError ? (
      <div class="p-6 border border-red-900/10 bg-red-900/5 rounded-xl text-red-500 text-xs font-mono">
        SIGNAL_LOST: {dbError}
      </div>
    ) : (
      <div class="flex flex-col gap-1">
        {opportunities.map((opp) => (
          <a 
            href={opp.url} 
            target="_blank" 
            class="flex items-center justify-between p-4 rounded-lg bg-[#0a0a0a] border border-white/5 hover:bg-[#0f0f0f] hover:border-blue-500/20 transition-all group"
          >
            <div class="flex items-center gap-6">
              <span class="text-[10px] font-mono text-zinc-700 font-bold w-12">{opp.date}</span>
              <div class="h-4 w-[1px] bg-white/5"></div>
              <div>
                <div class="text-[11px] font-black text-white uppercase tracking-tight group-hover:text-blue-500 transition-colors">
                  {opp.title}
                </div>
                <div class="text-[9px] text-zinc-600 font-bold uppercase tracking-widest mt-0.5">
                  {opp.company}
                </div>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-[9px] font-black text-zinc-800 uppercase tracking-widest group-hover:text-zinc-500 transition-colors">
                {opp.source}
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-800 group-hover:text-blue-500 transition-colors"><path d="M7 7h10v10"></path><path d="M7 17L17 7"></path></svg>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
</Layout>
