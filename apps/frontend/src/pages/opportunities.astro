---
import Layout from '../layouts/Layout.astro';
import { db } from '@va-hub/db/client';
import { opportunities as opportunitiesTable } from '@va-hub/db/schema';
import { desc } from 'drizzle-orm';

// Fetch live opportunities
let liveOpportunities = [];
let dbError = null;

if (!process.env.TURSO_DATABASE_URL || !process.env.TURSO_AUTH_TOKEN) {
  dbError = `ENV_MISSING: Database credentials not configured. Add TURSO_DATABASE_URL and TURSO_AUTH_TOKEN in Vercel Dashboard → Settings → Environment Variables.`;
} else {
  try {
    liveOpportunities = await db.select()
      .from(opportunitiesTable)
      .orderBy(desc(opportunitiesTable.postedAt))
      .limit(100);
  } catch (e) {
    console.error("Database fetch failed:", e);
    dbError = e.message;
  }
}


function formatRelativeTime(dateInput: Date | null) {
  if (!dateInput) return 'Today';
  const now = new Date();
  const date = new Date(dateInput);
  const diffHours = Math.floor((now.getTime() - date.getTime()) / (1000 * 60 * 60));
  
  if (diffHours < 1) return 'Just Now';
  if (diffHours < 24) return `${diffHours}h ago`;
  
  const diffDays = Math.floor(diffHours / 24);
  if (diffDays === 1) return '1d ago';
  if (diffDays < 7) return `${diffDays}d ago`;
  
  return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
}

const opportunities = liveOpportunities.map((opp) => ({
  title: opp.title,
  company: opp.company || 'Direct Hire',
  date: formatRelativeTime(opp.postedAt),
  url: opp.sourceUrl,
  source: opp.sourcePlatform || 'Web',
}));
---

<Layout title="Opportunities | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-12">
      <div class="flex items-center gap-2 mb-4 group cursor-default">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blue-500 tracking-[0.2em] uppercase transition-all group-hover:tracking-[0.4em]">LIVE OPPORTUNITIES</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-black text-white tracking-tighter mb-4">Latest Roles</h1>
      <p class="text-zinc-500 max-w-xl text-sm leading-relaxed font-medium">
        Fresh hiring signals captured from Reddit, Brave, and curated boards.
      </p>

      <div class="mt-10 relative group max-w-xl">
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 text-zinc-700 w-4 h-4 transition-colors group-focus-within:text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
        <input 
          type="text" 
          id="oppSearch" 
          placeholder="Search jobs, titles, or companies..." 
          class="bg-brand-dark border border-white/5 rounded-2xl pl-11 pr-4 py-3 text-sm text-white focus:outline-none focus:border-blue-500/30 focus:bg-[#0f0f0f] transition-all font-medium placeholder:text-zinc-800 w-full"
        />
      </div>
    </header>

    {dbError ? (
      <div class="p-6 border border-red-900/10 bg-red-900/5 rounded-xl text-red-500 text-xs font-mono">
        SIGNAL_LOST: {dbError}
      </div>
    ) : (
      <div class="flex flex-col gap-2" id="oppsGrid">
        {opportunities.map((opp) => (
          <a 
            href={opp.url} 
            target="_blank" 
            class="opp-item flex items-center justify-between p-4 rounded-2xl bg-brand-dark border border-white/5 hover:bg-[#0f0f0f] hover:border-blue-500/20 active:scale-[0.99] transition-all group"
            data-search={`${opp.title} ${opp.company} ${opp.source}`.toLowerCase()}
          >
            <div class="flex items-center gap-4 md:gap-8">
              <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
                <span class="text-[10px] font-mono text-zinc-700 font-black w-14 hidden md:block">{opp.date}</span>
                <div class="h-4 w-[1px] bg-white/5 hidden md:block"></div>
                <div>
                  <div class="text-[11px] font-black text-white uppercase tracking-tight group-hover:text-blue-500 transition-colors">
                    {opp.title}
                  </div>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="text-[9px] text-zinc-600 font-bold uppercase tracking-widest leading-none">
                      {opp.company}
                    </span>
                    <span class="md:hidden text-[9px] text-zinc-800 font-black uppercase tracking-widest leading-none">• {opp.date}</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-6">
              <span class="text-[9px] font-black text-zinc-800 uppercase tracking-widest hidden sm:block group-hover:text-zinc-500 transition-colors">
                {opp.source}
              </span>
              <div class="w-8 h-8 rounded-full bg-white/5 border border-white/5 group-hover:border-blue-500/20 group-hover:bg-blue-500/10 flex items-center justify-center transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-800 group-hover:text-blue-500 transition-colors"><path d="M7 7h10v10"></path><path d="M7 17L17 7"></path></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

    <div id="emptyState" class="hidden py-24 text-center">
      <div class="w-16 h-16 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-700"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
      </div>
      <h3 class="text-white font-black text-xl mb-2">No roles found</h3>
      <p class="text-zinc-600 text-sm">Try using different keywords or check back soon.</p>
    </div>
  </main>
</Layout>

<script>
  function init() {
    const searchInput = document.getElementById('oppSearch') as HTMLInputElement;
    const grid = document.getElementById('oppsGrid');
    const emptyState = document.getElementById('emptyState');
    const items = grid?.querySelectorAll('.opp-item');

    function runFilter() {
      const query = searchInput?.value.toLowerCase() || '';
      let hasResults = false;
      
      items?.forEach((item: any) => {
        const searchText = item.getAttribute('data-search') || '';
        const isVisible = searchText.includes(query);
        item.style.display = isVisible ? 'flex' : 'none';
        if (isVisible) hasResults = true;
      });

      if (emptyState) emptyState.style.display = hasResults ? 'none' : 'block';
    }

    searchInput?.addEventListener('input', runFilter);
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
