---
import Layout from '../layouts/Layout.astro';
import { db } from '@va-hub/db/client';
import { opportunities as opportunitiesTable } from '@va-hub/db/schema';
import { desc } from 'drizzle-orm';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'max-age=0, s-maxage=60, stale-while-revalidate=59');

let liveOpportunities = [];
let dbError = null;

try {
  liveOpportunities = await db.select()
    .from(opportunitiesTable)
    .orderBy(desc(opportunitiesTable.scrapedAt))
    .limit(1000); // Fetch more to allow for diversity slicing
} catch (e) {
  dbError = e.message;
}

function formatRelativeTime(dateInput: Date | null) {
  if (!dateInput) return 'Just Now';
  const now = new Date();
  const date = new Date(dateInput);
  const diffMs = now.getTime() - date.getTime();
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  
  if (diffMs < 3600000) return 'Just Now'; // < 1 hour
  if (diffHours < 24) return `${diffHours}h ago`;
  
  const diffDays = Math.floor(diffHours / 24);
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays}d ago`;
  
  return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
}

const PH_FRIENDLY_COMPANIES = ["virtualstaff", "onlinejobs", "remote staff", "bruntwork", "athena", "cyberbacker", "outsourced", "filta"];

function getScore(opp: any) {
  const title = (opp.title || "").toLowerCase();
  const company = (opp.company || "").toLowerCase();
  const desc = (opp.description || "").toLowerCase();
  const text = `${title} ${company} ${desc}`.toLowerCase();
  
  let score = 0;

  // Axis 1: FRESHNESS (The ultimate decider)
  const now = Date.now();
  const scrapedAt = new Date(opp.scrapedAt).getTime();
  const ageHrs = (now - scrapedAt) / (1000 * 60 * 60);
  
  if (ageHrs < 1) score += 1000000;
  else if (ageHrs < 4) score += 500000;
  else if (ageHrs < 24) score += 100000;
  else if (ageHrs < 72) score += 50000;

  // Axis 2: FILIPINO AFFINITY
  const phSignals = ["philippines", "filipino", "pinoy", "tagalog", "worldwide", "global", "remote ph", "home-based"];
  if (phSignals.some(s => text.includes(s))) score += 50000;
  if (PH_FRIENDLY_COMPANIES.some(c => company.includes(c))) score += 30000;

  // Axis 3: ACCESSIBILITY (Non-Techy / Entry Level)
  const vaKeywords = ["virtual assistant", "assistant", "cs", "customer service", "support", "admin", "data entry", "bookkeeping", "executive", "marketing", "social media"];
  if (vaKeywords.some(k => title.includes(k))) score += 40000;

  // Axis 4: DATA HARVEST / OVER-TECH PENALTY
  const techHarvesterSignals = ["senior", "lead", "principal", "staff engineer", "architect", "manager", "vp", "director"];
  const isHarvester = techHarvesterSignals.some(s => title.includes(s)) && !text.includes("philippines");
  if (isHarvester) score -= 200000;

  return score;
}

// 1. Scoring & Initial Sort
const scored = liveOpportunities.map(opp => ({
  ...opp,
  relevancyScore: getScore(opp)
})).sort((a, b) => b.relevancyScore - a.relevancyScore);

// 2. Fuzzy Dedup & Company Diversity
const seenFingerprints = new Set();
const companyUsage = new Map();
const finalFeed = [];

for (const opp of scored) {
  const normTitle = opp.title.toLowerCase().replace(/[^a-z0-9]/g, '').slice(0, 30);
  const normCompany = (opp.company || 'unknown').toLowerCase().trim();
  const fingerprint = `${normTitle}|${normCompany}`;
  
  if (seenFingerprints.has(fingerprint)) continue;

  // Dynamic Slot Budget
  const isPhFriendly = PH_FRIENDLY_COMPANIES.some(c => normCompany.includes(c)) || opp.relevancyScore > 100000;
  const slotLimit = isPhFriendly ? 3 : 1;
  const currentUsage = companyUsage.get(normCompany) || 0;

  if (currentUsage < slotLimit) {
    seenFingerprints.add(fingerprint);
    companyUsage.set(normCompany, currentUsage + 1);
    
    // Final UI Prep
    const latestDate = new Date(Math.max(new Date(opp.postedAt || 0).getTime(), new Date(opp.scrapedAt).getTime()));
    const ageHrs = (Date.now() - latestDate.getTime()) / (1000 * 60 * 60);

    finalFeed.push({
      ...opp,
      displayDate: formatRelativeTime(latestDate),
      ageHrs
    });
  }

  if (finalFeed.length >= 200) break;
}
---

<Layout title="Feed | VA.INDEX">
  <main class="max-w-[1240px] mx-auto px-6 py-12">
    <header class="mb-12">
      <div class="flex items-center gap-2 mb-6">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blueberry-500 tracking-[0.2em] uppercase">SYSTEM_LIVE: RELEVANCY_V2</span>
      </div>
      
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-10">
        <div>
          <h1 class="text-4xl md:text-6xl font-black text-blueberry-900 tracking-tighter mb-4 leading-none uppercase">
            Live Feed
          </h1>
          <p class="text-blueberry-800/60 font-medium max-w-xl text-sm leading-relaxed uppercase tracking-wide">
            Intelligently ranked by recency, trust, and Filipino accessibility.
          </p>
        </div>
      </div>

      <div class="flex flex-col md:flex-row items-center gap-4">
        <div class="relative flex-1 group">
          <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 text-blueberry-800/30 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          <input 
            type="text" 
            id="oppSearch" 
            placeholder="Filter roles, companies, or keywords..." 
            class="bg-white border border-blueberry-800/10 rounded-2xl pl-12 pr-6 py-4 text-sm w-full focus:outline-none focus:border-blueberry-500 shadow-sm font-medium transition-all"
          />
        </div>
        <div class="flex p-1 bg-white border border-blueberry-800/10 rounded-2xl shadow-sm self-start overflow-hidden" id="timeFilters">
          <button data-filter="all" class="time-btn active">All</button>
          <button data-filter="24" class="time-btn text-emerald-600">24h</button>
          <button data-filter="72" class="time-btn">3d</button>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 gap-3" id="oppsGrid">
      {finalFeed.map((opp) => (
        <a 
          href={opp.sourceUrl} 
          target="_blank" 
          class="opp-item flex items-center justify-between p-5 rounded-[2.5rem] bg-white border border-blueberry-800/5 hover:border-blueberry-500/20 hover:shadow-xl transition-all group relative active:scale-[0.99]"
          data-search={`${opp.title} ${opp.company}`.toLowerCase()}
          data-age={opp.ageHrs}
        >
          <div class="flex items-center gap-6">
            <div class="w-20 flex flex-col items-center">
              <span class="text-[10px] font-black text-blueberry-800/40 uppercase tracking-tighter mb-1">{opp.displayDate}</span>
              {opp.ageHrs < 1 ? (
                <span class="px-2 py-0.5 bg-emerald-500 text-white text-[8px] font-black uppercase rounded-lg shadow-sm">Just Now</span>
              ) : opp.ageHrs < 24 ? (
                <span class="px-2 py-0.5 bg-blueberry-50 text-blueberry-500 text-[8px] font-black uppercase rounded-lg border border-blueberry-500/10">Recent</span>
              ) : null}
            </div>
            <div class="h-10 w-[1px] bg-blueberry-800/5"></div>
            <div>
              <h3 class="text-[15px] font-black text-blueberry-900 group-hover:text-blueberry-500 transition-colors leading-tight mb-1 uppercase tracking-tight">{opp.title}</h3>
              <div class="flex items-center gap-2">
                <span class="text-[10px] text-blueberry-800/60 font-bold uppercase tracking-widest">{opp.company}</span>
                {opp.relevancyScore > 1000000 && <span class="text-[10px]">🔥</span>}
              </div>
            </div>
          </div>
          <div class="flex items-center gap-4 text-blueberry-800/20">
             <span class="text-[9px] font-black uppercase tracking-[0.2em] hidden sm:block">{opp.sourcePlatform}</span>
             <div class="w-10 h-10 rounded-full bg-blueberry-50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all scale-75 group-hover:scale-100">
               <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blueberry-500"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
             </div>
          </div>
        </a>
      ))}
    </div>

    <div id="emptyState" class="hidden py-40 text-center text-blueberry-800/30 font-black uppercase tracking-widest text-sm italic">
      No matching signals found.
    </div>
  </main>
</Layout>

<script is:inline>
  function initFeed() {
    const search = document.getElementById('oppSearch');
    const filters = document.getElementById('timeFilters');
    const grid = document.getElementById('oppsGrid');
    const empty = document.getElementById('emptyState');
    if (!grid) return;

    const items = grid.querySelectorAll('.opp-item');
    const btns = filters?.querySelectorAll('.time-btn');
    let q = "";
    let limit = Infinity;

    function run() {
      let count = 0;
      items.forEach(el => {
        const text = el.dataset.search || "";
        const age = parseFloat(el.dataset.age || "999");
        const match = text.includes(q) && age <= limit;
        el.style.display = match ? 'flex' : 'none';
        if (match) count++;
      });
      if (empty) empty.style.display = count > 0 ? 'none' : 'block';
    }

    search?.addEventListener('input', (e) => {
      q = e.target.value.toLowerCase().trim();
      run();
    });

    btns?.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const val = btn.dataset.filter;
        limit = val === 'all' ? Infinity : parseFloat(val);
        run();
      });
    });

    run();
  }

  if (!window._feedInitSet) {
    document.addEventListener('astro:after-swap', initFeed);
    window._feedInitSet = true;
  }
  initFeed();
</script>

<style>
  .time-btn {
    @apply px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all cursor-pointer text-blueberry-800/40 hover:text-blueberry-900;
  }
  .time-btn.active {
    @apply bg-blueberry-50 text-blueberry-900 shadow-inner;
  }
  .opp-item {
    box-shadow: 0 4px 20px -10px rgba(40, 53, 147, 0.05);
  }
</style>
