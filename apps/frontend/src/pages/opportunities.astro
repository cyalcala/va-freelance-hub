---
import Layout from '../layouts/Layout.astro';
import { db } from '@va-hub/db/client';
import { opportunities as opportunitiesTable } from '@va-hub/db/schema';
import { desc } from 'drizzle-orm';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'max-age=0, s-maxage=60, stale-while-revalidate=59');

// Fetch live opportunities
let liveOpportunities = [];
let dbError = null;

if (!process.env.TURSO_DATABASE_URL || !process.env.TURSO_AUTH_TOKEN) {
  dbError = `ENV_MISSING: Database credentials not configured. Add TURSO_DATABASE_URL and TURSO_AUTH_TOKEN in Vercel Dashboard → Settings → Environment Variables.`;
} else {
  try {
    liveOpportunities = await db.select()
      .from(opportunitiesTable)
      .orderBy(desc(opportunitiesTable.postedAt))
      .limit(100);
  } catch (e) {
    console.error("Database fetch failed:", e);
    dbError = e.message;
  }
}


function formatRelativeTime(dateInput: Date | null) {
  if (!dateInput) return 'Today';
  const now = new Date();
  const date = new Date(dateInput);
  const diffHours = Math.floor((now.getTime() - date.getTime()) / (1000 * 60 * 60));
  
  if (diffHours <= 4) return 'Just Now';
  if (diffHours < 24) return `${diffHours}h ago`;
  
  const diffDays = Math.floor(diffHours / 24);
  if (diffDays === 1) return '1d ago';
  if (diffDays < 7) return `${diffDays}d ago`;
  
  return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
}

function calculateRelevance(opp: any) {
  const text = `${opp.title} ${opp.company} ${opp.description || ''} ${opp.tags || ''}`.toLowerCase();
  let score = 0;
  
  const now = Date.now();
  const postedAt = opp.postedAt ? new Date(opp.postedAt).getTime() : 0;
  const ageHours = postedAt ? (now - postedAt) / (1000 * 60 * 60) : 999;
  
  // 1. Core Penalty (-50,000 Pts)
  const penaltyKw = ["senior", "vp", "president", "director", "principal", "staff", "head of", "lead", "usa only", "us only", "strictly us", "americas"];
  if (penaltyKw.some(k => text.includes(k))) score -= 50000;

  // 2. Niche Boost (+10,000 Pts)
  const boostKw = ["virtual assistant", "va", "customer service", "customer support", "sales", "design", "web design", "executive assistant", "marketing", "admin", "bookkeeping", "data entry"];
  if (boostKw.some(k => text.includes(k))) score += 10000;

  // 3. Native Inclusion Boost (+10,000 Pts)
  const inclusionKw = ["philippines", "filipino", "pinoy", "manila", "cebu", "worldwide", "global", "anywhere", "any timezone", "international"];
  if (inclusionKw.some(k => text.includes(k))) score += 10000;

  // 4. Absolute Peak Boost (+20,000 Pts)
  if (text.includes("virtual assistant") || text.includes("filipino")) score += 20000;
  
  // 5. The "JUST NOW" Recency Velocity (+1,000 to +5,000 Pts)
  if (ageHours <= 4) {
    score += 5000; 
  } else if (ageHours <= 24) {
    score += 1000;
  }

  return score;
}

const scoredOpps = liveOpportunities.map(opp => ({
  ...opp,
  relevancyScore: calculateRelevance(opp)
})).sort((a, b) => {
  if (a.relevancyScore !== b.relevancyScore) return b.relevancyScore - a.relevancyScore;
  return new Date(b.postedAt || 0).getTime() - new Date(a.postedAt || 0).getTime();
});

const opportunities = scoredOpps.map((opp) => ({
  title: opp.title,
  company: opp.company || 'Direct Hire',
  date: formatRelativeTime(opp.postedAt),
  url: opp.sourceUrl,
  source: opp.sourcePlatform || 'Web',
}));
---

<Layout title="Opportunities | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-12">
      <div class="flex items-center gap-2 mb-4 group cursor-default">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blueberry-500 tracking-[0.2em] uppercase transition-all group-hover:tracking-[0.4em]">LIVE OPPORTUNITIES</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-black text-blueberry-900 tracking-tighter mb-4">Latest Roles</h1>
      <p class="text-blueberry-800/70 max-w-xl text-sm leading-relaxed font-medium">
        Fresh hiring signals captured from Reddit, Brave, and curated boards.
      </p>

      <div class="mt-10 relative group max-w-xl">
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 text-blueberry-800/40 w-4 h-4 transition-colors group-focus-within:text-blueberry-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
        <input 
          type="text" 
          id="oppSearch" 
          placeholder="Search jobs, titles, or companies..." 
          class="bg-white/80 border border-blueberry-800/10 rounded-2xl pl-11 pr-4 py-3 text-sm text-blueberry-900 shadow-sm focus:outline-none focus:border-blueberry-500/40 focus:bg-white transition-all font-medium placeholder:text-blueberry-800/40 w-full"
        />
      </div>
    </header>

    {dbError ? (
      <div class="p-6 border border-red-900/10 bg-red-900/5 rounded-xl text-red-500 text-xs font-mono">
        SIGNAL_LOST: {dbError}
      </div>
    ) : (
      <div class="flex flex-col gap-2" id="oppsGrid">
        {opportunities.map((opp) => (
          <a 
            href={opp.url} 
            target="_blank" 
            class="opp-item flex items-center justify-between p-4 rounded-2xl bg-white border border-blueberry-800/10 hover:bg-oat-100/50 hover:border-blueberry-500/30 active:scale-[0.99] transition-all group shadow-sm"
            data-search={`${opp.title} ${opp.company} ${opp.source}`.toLowerCase()}
          >
            <div class="flex items-center gap-4 md:gap-8">
              <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
                <span class="text-[10px] font-mono text-blueberry-800/50 font-black w-14 hidden md:block">{opp.date}</span>
                <div class="h-4 w-[1px] bg-blueberry-800/10 hidden md:block"></div>
                <div>
                  <div class="text-[11px] font-black text-blueberry-900 uppercase tracking-tight group-hover:text-blueberry-600 transition-colors">
                    {opp.title}
                  </div>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="text-[9px] text-blueberry-800/60 font-bold uppercase tracking-widest leading-none">
                      {opp.company}
                    </span>
                    <span class="md:hidden text-[9px] text-blueberry-800/40 font-black uppercase tracking-widest leading-none">• {opp.date}</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-6">
              <span class="text-[9px] font-black text-blueberry-800/40 uppercase tracking-widest hidden sm:block group-hover:text-blueberry-800/70 transition-colors">
                {opp.source}
              </span>
              <div class="w-8 h-8 rounded-full bg-oat-50 border border-blueberry-800/10 group-hover:border-blueberry-500/30 group-hover:bg-blueberry-50 flex items-center justify-center transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="text-blueberry-800/40 group-hover:text-blueberry-600 transition-colors"><path d="M7 7h10v10"></path><path d="M7 17L17 7"></path></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

    <div id="emptyState" class="hidden py-24 text-center">
      <div class="w-16 h-16 bg-white shadow-sm border border-blueberry-800/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blueberry-800/40"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
      </div>
      <h3 class="text-blueberry-900 font-black text-xl mb-2">No roles found</h3>
      <p class="text-blueberry-800/60 text-sm">Try using different keywords or check back soon.</p>
    </div>
  </main>
</Layout>

<script>
  function init() {
    const searchInput = document.getElementById('oppSearch') as HTMLInputElement;
    const grid = document.getElementById('oppsGrid');
    const emptyState = document.getElementById('emptyState');
    const items = grid?.querySelectorAll('.opp-item');

    function runFilter() {
      const query = searchInput?.value.toLowerCase() || '';
      let hasResults = false;
      
      items?.forEach((item: any) => {
        const searchText = item.getAttribute('data-search') || '';
        const isVisible = searchText.includes(query);
        item.style.display = isVisible ? 'flex' : 'none';
        if (isVisible) hasResults = true;
      });

      if (emptyState) emptyState.style.display = hasResults ? 'none' : 'block';
    }

    searchInput?.addEventListener('input', runFilter);
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
