---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { db, logs } from '@va-hub/db';
import { desc } from 'drizzle-orm';

// --- SECURITY GATE ---
const ADMIN_TOKEN = process.env.ADMIN_TOKEN;
const providedToken = Astro.url.searchParams.get('token') || Astro.request.headers.get('x-admin-token');

if (process.env.NODE_ENV === 'production' && (!ADMIN_TOKEN || providedToken !== ADMIN_TOKEN)) {
  return new Response('401 Unauthorized: Access Denied to VA.INDEX Sentinels', { status: 401 });
}

const allLogs = await db.select().from(logs).orderBy(desc(logs.timestamp)).limit(100);

function safeJsonParse(data: string | null) {
  if (!data || data === '{}') return null;
  try {
    return JSON.parse(data);
  } catch {
    return { error: "Malformed Metadata", raw: data };
  }
}

function getLevelColor(level: string) {
  switch (level) {
    case 'error': return 'bg-red-500 text-white';
    case 'warn': return 'bg-amber-500 text-blueberry-900';
    case 'snapshot': return 'bg-purple-500 text-white shadow-[0_0_10px_rgba(168,85,247,0.5)]';
    default: return 'bg-blueberry-900 text-white/50';
  }
}

function getIndicatorColor(level: string) {
  switch (level) {
    case 'error': return 'bg-red-500';
    case 'warn': return 'bg-amber-500';
    case 'snapshot': return 'bg-purple-500 scale-150 animate-pulse';
    default: return 'bg-emerald-500';
  }
}

Astro.response.headers.set('Cache-Control', 'private, no-cache, no-store, must-revalidate');
---

<Layout title="System Logs | VA.INDEX">
  <main class="max-w-[1000px] mx-auto px-6 py-12">
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-2 w-2 rounded-full bg-emerald-500 animate-ping"></div>
        <span class="text-[10px] font-black text-blueberry-500 tracking-[0.4em] uppercase">Meta-SRE Sentinels / Live Terminal</span>
      </div>
      <h1 class="text-5xl font-black text-blueberry-900 leading-[0.9] tracking-tighter uppercase mb-6">
        System <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-500">Activity Logs</span>
      </h1>
      <p class="text-blueberry-800/60 font-bold uppercase text-xs tracking-widest max-w-xl leading-loose">
        Real-time telemetry from the harvesting engine and mythical restore points. 
        Auto-snapshotting every 15 minutes. Heartbeat active.
      </p>
    </header>

    <div class="bg-[#FDFBF7] border-2 border-oat-200/50 rounded-[2.5rem] overflow-hidden shadow-sm backdrop-blur-xl">
      <div class="bg-blueberry-900 p-4 px-8 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <div class="flex gap-1.5">
            <div class="h-2.5 w-2.5 rounded-full bg-red-400/20"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-amber-400/20"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-emerald-400/20"></div>
          </div>
          <span class="text-[9px] font-black text-white/20 uppercase tracking-[0.3em]">VA_INDEX_LOGS_V1.0</span>
        </div>
        <div class="text-[9px] font-medium text-white/40 uppercase tracking-widest" hx-get="/terminal" hx-trigger="every 10s" hx-select=".log-stream" hx-target=".log-stream" hx-swap="outerHTML">
          Syncing in Real-time...
        </div>
      </div>

      <div class="p-2 log-stream min-h-[600px] max-h-[800px] overflow-y-auto scrollbar-hide">
        {allLogs.length === 0 ? (
          <div class="py-40 text-center">
            <div class="text-blueberry-900/10 text-6xl font-black uppercase mb-4 tracking-tighter italic">SILENCE.</div>
            <p class="text-[10px] font-black text-blueberry-800/30 uppercase tracking-[0.4em]">No signals captured yet.</p>
          </div>
        ) : (
          <div class="flex flex-col gap-1">
            {allLogs.map((log) => (
              <div class="flex gap-4 p-4 rounded-2xl hover:bg-white/50 transition-colors group">
                <div class="w-20 text-[10px] font-black text-blueberry-900/20 uppercase tracking-tighter shrink-0 pt-0.5">
                  {new Date(log.timestamp).toLocaleTimeString([], { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' })}
                </div>
                
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-1">
                    <div class={`h-1.5 w-1.5 rounded-full ${getIndicatorColor(log.level || 'info')}`}></div>
                    <span class={`text-[8px] font-black px-1.5 py-0.5 rounded uppercase tracking-widest ${getLevelColor(log.level || 'info')}`}>
                      {log.level}
                    </span>
                    <span class="h-px flex-1 bg-oat-200/30"></span>
                  </div>
                  <p class="text-[13px] font-bold text-blueberry-900 leading-tight group-hover:text-emerald-600 transition-colors">
                    {log.message}
                  </p>
                  {log.metadata && log.metadata !== '{}' && (
                    <pre class="mt-2 p-3 bg-blueberry-900/5 rounded-xl text-[10px] text-blueberry-900/60 font-mono overflow-x-auto border-dashed border border-blueberry-900/10">
                      {JSON.stringify(safeJsonParse(log.metadata), null, 2)}
                    </pre>
                  )}
                </div>

                {log.level === 'snapshot' && (
                  <div class="shrink-0 flex items-center pr-2">
                     <button class="bg-blueberry-900 text-white text-[9px] font-black px-3 py-1.5 rounded-full uppercase tracking-widest hover:bg-purple-600 transition-all shadow-sm active:scale-95">
                        RESTORE
                     </button>
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
    </div>

    <footer class="mt-12 flex items-center justify-between px-6">
       <div class="flex items-center gap-6">
          <div class="flex flex-col">
             <span class="text-[9px] font-black text-blueberry-900/30 uppercase tracking-[0.2em]">Platform Integrity</span>
             <span class="text-[11px] font-bold text-emerald-500 uppercase tracking-tighter">100% Operational</span>
          </div>
          <div class="w-px h-6 bg-oat-200"></div>
          <div class="flex flex-col">
             <span class="text-[9px] font-black text-blueberry-900/30 uppercase tracking-[0.2em]">Active Sentinels</span>
             <span class="text-[11px] font-bold text-blueberry-900 uppercase tracking-tighter">Hyperflow v5.2</span>
          </div>
       </div>
       <a href="/" class="text-[10px] font-black text-blueberry-900/40 uppercase tracking-[0.3em] hover:text-blueberry-500 transition-colors">
          &larr; Return to Core Feed
       </a>
    </footer>
  </main>
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
