---
import Layout from '../layouts/Layout.astro';
import { db } from '@va-hub/db/client';
import { agencies as agenciesTable } from '@va-hub/db/schema';
import { desc } from 'drizzle-orm';

Astro.response.headers.set('Cache-Control', 'max-age=0, s-maxage=60, stale-while-revalidate=59');
export const prerender = false;

let liveAgencies = [];
let dbError = null;

try {
  liveAgencies = await db.select()
    .from(agenciesTable)
    .orderBy(
      agenciesTable.frictionLevel,  
      desc(agenciesTable.hiringHeat), 
      desc(agenciesTable.createdAt)
    )
    .limit(100);
} catch (e) {
  dbError = e.message;
}

const agencies = liveAgencies.map((agency) => {
  const isNew = agency.createdAt && (new Date().getTime() - new Date(agency.createdAt).getTime()) < 30 * 24 * 60 * 60 * 1000;
  const heatFlame = "🔥".repeat(agency.hiringHeat || 1);
  return {
    ...agency,
    description: agency.description || 'Verified Filipino Agency Partner',
    sources: (agency.metadata as any)?.source?.split(',') || ['Web'],
    isNew,
    heat: heatFlame,
  };
});
---

<Layout title="Agencies | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-16">
      <div class="flex items-center gap-2 mb-6 cursor-default">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blue-500 tracking-[0.2em] uppercase">SYSTEM_LIVE</span>
      </div>
      
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 mb-12">
        <div class="max-w-2xl">
          <h1 class="text-4xl sm:text-6xl font-black text-blueberry-900 mb-6 leading-[0.9] tracking-tighter uppercase">
            The Hiring Signal, <span class="text-transparent bg-clip-text bg-gradient-to-r from-blueberry-500 to-indigo-500">Automated.</span>
          </h1>
          <p class="text-lg text-blueberry-800/70 font-medium max-w-xl">
            Scanning recruitment channels every 120 minutes for verified Filipino agencies.
          </p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <input 
          type="text" 
          id="agencySearch"
          placeholder="Search agencies, niches..." 
          class="bg-white border border-blueberry-800/10 rounded-2xl px-6 py-4 text-sm w-full max-w-md focus:outline-none focus:border-blueberry-500/40 transition-all font-medium shadow-sm"
        />
        <button id="verifiedFilter" class="w-full sm:w-auto px-8 py-4 bg-white border border-blueberry-800/10 rounded-2xl text-[11px] font-black uppercase tracking-widest text-blueberry-800/50 hover:text-blueberry-900 hover:border-blueberry-500/30 active:scale-95 transition-all shadow-sm cursor-pointer">
          Hiring Now Only
        </button>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="agenciesGrid">
      {agencies.map((agency) => (
        <a 
          href={agency.hiringUrl || '#'} 
          target="_blank" 
          class="glass-card flex flex-col justify-between group h-full relative overflow-hidden active:scale-[0.98]" 
          data-name={agency.name.toLowerCase()} 
          data-status={agency.status}
        >
          <div>
            <div class="flex justify-between items-start mb-6">
              <div class="text-base font-black text-blueberry-900 tracking-tight group-hover:text-blueberry-500 transition-colors uppercase">{agency.name}</div>
              <div class="flex flex-col items-end gap-2 text-[8px] font-black">
                {agency.status === 'active' && <span class="text-emerald-500 uppercase">● Hiring</span>}
                <span class="grayscale group-hover:grayscale-0">{agency.heat}</span>
              </div>
            </div>
            <p class="text-[12px] text-blueberry-800/70 line-clamp-3 leading-relaxed font-medium">{agency.description}</p>
          </div>
          <div class="mt-8 flex flex-wrap gap-2">
            {agency.sources.map((s) => <span class="px-2 py-1 bg-oat-100/50 rounded-md text-[8px] font-black uppercase text-blueberry-800/40">{s}</span>)}
          </div>
        </a>
      ))}
    </div>

    <div id="emptyState" class="hidden py-32 text-center text-blueberry-800/40 text-sm italic">
      No agencies match your search.
    </div>
  </main>
</Layout>

<script is:inline>
  function setupAgencies() {
    console.log("[Agencies] INIT_INTERACTION_LAYER");
    setTimeout(() => {
      const search = document.getElementById('agencySearch');
      const filterBtn = document.getElementById('verifiedFilter');
      const grid = document.getElementById('agenciesGrid');
      const empty = document.getElementById('emptyState');
      
      if (!grid || !search || !filterBtn) {
        console.warn("[Agencies] Elements missing, retrying...");
        return;
      }

      const cards = grid.querySelectorAll('.glass-card');
      let activeOnly = false;

      function refresh() {
        const q = search.value.toLowerCase();
        let count = 0;
        cards.forEach(card => {
          const name = card.getAttribute('data-name') || '';
          const status = card.getAttribute('data-status');
          const show = name.includes(q) && (!activeOnly || status === 'active');
          card.style.display = show ? 'flex' : 'none';
          if (show) count++;
        });
        if (empty) empty.style.display = count > 0 ? 'none' : 'block';
      }

      search.oninput = refresh;
      
      filterBtn.onclick = (e) => {
        e.preventDefault();
        activeOnly = !activeOnly;
        filterBtn.classList.toggle('active-filter', activeOnly);
        filterBtn.innerText = activeOnly ? '✓ Showing Hiring' : 'Hiring Now Only';
        refresh();
      };
      
      console.log(`[Agencies] BINDING_SUCCESS: ${cards.length} cards.`);
    }, 50);
  }

  setupAgencies();
  document.addEventListener('astro:page-load', setupAgencies);
  document.addEventListener('astro:after-swap', setupAgencies);
</script>

<style>
  .time-btn {
    @apply px-4 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all cursor-pointer;
    @apply text-blueberry-800/40 hover:text-blueberry-900;
  }
  .time-btn.active {
    @apply bg-blueberry-50 text-blueberry-900 border border-blueberry-800/10;
  }
</style>
