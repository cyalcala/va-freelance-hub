---
import Layout from '../layouts/Layout.astro';
import { db } from '@va-hub/db/client';
import { agencies as agenciesTable } from '@va-hub/db/schema';
import { desc } from 'drizzle-orm';

// Fetch live agencies
let liveAgencies = [];
let dbError = null;

try {
  liveAgencies = await db.select()
    .from(agenciesTable)
    .orderBy(
      agenciesTable.frictionLevel,  // Easiest (1) first
      desc(agenciesTable.hiringHeat), // Hottest (3) next
      desc(agenciesTable.createdAt)
    )
    .limit(100);
} catch (e) {
  console.error("Database fetch failed:", e);
  dbError = e.message;
}

const agencies = liveAgencies.map((agency) => {
  const isNew = agency.createdAt && (new Date().getTime() - new Date(agency.createdAt).getTime()) < 30 * 24 * 60 * 60 * 1000;
  const heatFlame = "🔥".repeat(agency.hiringHeat || 1);

  return {
    name: agency.name,
    description: agency.description || 'Verified Filipino Agency Partner',
    status: agency.status || 'active',
    hiringUrl: agency.hiringUrl || '#',
    sources: (agency.metadata as any)?.source?.split(',') || ['Web'],
    isNew,
    heat: heatFlame,
  };
});
---

<Layout title="Agencies | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-16 relative">
      <div class="flex items-center gap-2 mb-6 group cursor-default">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blue-500 tracking-[0.2em] uppercase transition-all group-hover:tracking-[0.4em]">V5.2 LIVE SIGNAL CAPTURE</span>
      </div>
      
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 mb-12">
        <div class="max-w-2xl">
          <h1 class="text-4xl sm:text-6xl font-black text-white mb-6 leading-[0.9] tracking-tighter uppercase whitespace-pre-line">
            The Hiring Signal, 
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-indigo-400">Automated.</span>
          </h1>
          <p class="text-lg text-zinc-500 font-medium leading-relaxed max-w-xl">
            We scan 48+ recruitment channels every 120 minutes to capture high-fidelity hiring signals from verified Filipino agencies. Zero noise. Only live signals.
          </p>
        </div>
        
        <div class="flex flex-col items-end gap-3 text-right">
          <div class="px-4 py-2 bg-zinc-950 border border-white/5 rounded-2xl shadow-inner">
            <p class="text-[10px] font-black uppercase tracking-widest text-zinc-600 mb-1">Total Verified Channels</p>
            <p class="text-2xl font-black text-white tabular-nums">124 <span class="text-blue-500 text-sm">UP</span></p>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="relative w-full max-w-md group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-700 group-focus-within:text-blue-500 transition-colors"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          </div>
          <input 
            type="text" 
            id="agencySearch"
            placeholder="Search agencies, niches, or keywords..." 
            class="bg-brand-dark/50 border border-white/5 rounded-3xl pl-12 pr-6 py-4 text-sm text-white focus:outline-none focus:border-blue-500/30 focus:bg-[#0f0f0f]/80 backdrop-blur-xl transition-all font-medium placeholder:text-zinc-800 w-full"
          />
        </div>
        <button id="verifiedFilter" class="w-full sm:w-auto px-8 py-4 bg-zinc-950 border border-white/5 rounded-3xl text-[11px] font-black uppercase tracking-widest text-zinc-600 hover:text-white hover:border-blue-500/20 active:scale-95 transition-all shadow-inner">
          Verified Hiring Only
        </button>
      </div>
    </header>

    {dbError ? (
      <div class="p-8 border border-red-900/10 bg-red-900/5 rounded-3xl text-red-500 text-[10px] font-mono uppercase tracking-[0.1em]">
        SIGNAL_LOST: {dbError} — DATABASE_CONNECTION_FAILED
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="agenciesGrid">
        {agencies.map((agency) => (
          <a 
            href={agency.hiringUrl} 
            target="_blank" 
            class="glass-card flex flex-col justify-between group h-full relative overflow-hidden active:scale-[0.98]" 
            data-name={agency.name.toLowerCase()} 
            data-status={agency.status}
          >
            <div class="relative z-10">
              <div class="flex justify-between items-start mb-6">
                <div class="text-base font-black text-white tracking-tight group-hover:text-blue-500 transition-colors uppercase pr-4">
                  {agency.name}
                </div>
                <div class="flex flex-col items-end gap-2">
                  <div class={`flex items-center gap-1.5 px-3 py-1.5 rounded-full ${agency.status === 'active' ? 'bg-blue-500/10 border border-blue-500/20 shadow-[0_0_20px_-5px_rgba(59,130,246,0.35)]' : 'bg-zinc-900/50 border border-white/5'}`}>
                    <div class={agency.status === 'active' ? 'pulse-dot scale-75' : 'w-1.5 h-1.5 rounded-full bg-zinc-800'}></div>
                    <span class={`text-[9px] font-black uppercase tracking-tighter ${agency.status === 'active' ? 'text-blue-500' : 'text-zinc-600'}`}>
                      {agency.status === 'active' ? 'Hiring Now' : 'Quiet Signal'}
                    </span>
                  </div>
                  <div class="flex items-center gap-2">
                    {agency.isNew && (
                      <span class="text-[8px] font-black bg-blue-600 text-white px-2 py-0.5 rounded-md tracking-widest ">NEW</span>
                    )}
                    <span class="text-sm grayscale-[0.5] group-hover:grayscale-0 transition-all drop-shadow-[0_0_5px_rgba(255,100,0,0.2)]">{agency.heat}</span>
                  </div>
                </div>
              </div>
              <p class="text-[12px] text-zinc-500 line-clamp-3 leading-relaxed font-medium">
                {agency.description}
              </p>
            </div>
            
            <div class="mt-8 flex flex-wrap gap-2 relative z-10">
              {agency.sources.map((source) => (
                <span class="px-3 py-1 bg-zinc-950 border border-white/5 rounded-lg text-[9px] font-black text-zinc-600 uppercase tracking-wider group-hover:border-blue-500/10 group-hover:text-zinc-400 transition-all">
                  {source}
                </span>
              ))}
            </div>

            <div class="absolute -right-8 -bottom-8 w-16 h-16 bg-blue-600/5 blur-2xl rounded-full group-hover:bg-blue-600/10 transition-all"></div>
          </a>
        ))}
      </div>
    )}
    
    <div id="emptyState" class="hidden py-32 text-center animate-in fade-in slide-in-from-bottom-4 duration-500">
      <div class="w-20 h-20 bg-zinc-950 border border-white/5 rounded-3xl flex items-center justify-center mx-auto mb-8 shadow-inner">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-800"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
      </div>
      <h3 class="text-white font-black text-2xl mb-3 tracking-tight">Zero signals found</h3>
      <p class="text-zinc-600 font-medium max-w-sm mx-auto leading-relaxed">No agencies matched your search query. Try broadening your discovery keywords or clearing the hiring filter.</p>
    </div>

    <footer class="mt-32 pt-12 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-8 opacity-60 hover:opacity-100 transition-opacity">
       <div class="flex flex-col gap-2">
         <p class="text-[10px] font-black uppercase tracking-[0.3em] text-zinc-700">The Filipino Freelance Engine</p>
         <p class="text-xs text-zinc-500 font-medium italic">Empowering 1M+ remote workers through data transparency.</p>
       </div>
       <div class="flex items-center gap-6">
         <a href="https://www.linkedin.com/in/cyrusalcala/" target="_blank" class="flex items-center gap-3 group">
           <div class="text-right">
             <p class="text-[9px] font-black uppercase tracking-widest text-zinc-700 leading-none mb-1">Made with ❤️ by</p>
             <p class="text-xs font-black text-white group-hover:text-blue-500 transition-colors uppercase tracking-widest">Cy Alcala</p>
           </div>
           <div class="w-10 h-10 rounded-2xl bg-blue-600 flex items-center justify-center font-black text-sm shadow-[0_0_20px_-5px_rgba(59,130,246,0.35)] group-hover:scale-110 transition-transform">C</div>
         </a>
       </div>
    </footer>
  </main>
</Layout>

<script>
  function init() {
    const searchInput = document.getElementById('agencySearch') as HTMLInputElement;
    const verifiedBtn = document.getElementById('verifiedFilter');
    const grid = document.getElementById('agenciesGrid');
    const emptyState = document.getElementById('emptyState');
    const cards = grid?.querySelectorAll('.glass-card');

    let activeOnly = false;

    function runFilter() {
      const query = searchInput?.value.toLowerCase() || '';
      let hasResults = false;
      
      cards?.forEach((card: any) => {
        const name = card.getAttribute('data-name') || '';
        const status = card.getAttribute('data-status');
        const matchesSearch = name.includes(query);
        const matchesStatus = !activeOnly || status === 'active';
        
        const isVisible = matchesSearch && matchesStatus;
        card.style.display = isVisible ? 'flex' : 'none';
        if (isVisible) hasResults = true;
      });

      if (grid) grid.style.display = hasResults ? 'grid' : 'none';
      if (emptyState) emptyState.style.display = hasResults ? 'none' : 'block';
    }

    searchInput?.addEventListener('input', runFilter);
    verifiedBtn?.addEventListener('click', () => {
      activeOnly = !activeOnly;
      verifiedBtn.classList.toggle('bg-blue-500/10', activeOnly);
      verifiedBtn.classList.toggle('text-blue-500', activeOnly);
      verifiedBtn.classList.toggle('border-blue-500/30', activeOnly);
      runFilter();
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .glass-card {
    background: rgba(10, 10, 10, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 24px;
    padding: 32px;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 4px 24px -1px rgba(0, 0, 0, 0.2);
  }

  .glass-card:hover {
    background: rgba(15, 15, 15, 0.6);
    border-color: rgba(59, 130, 246, 0.2);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(59, 130, 246, 0.15);
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    background-color: #3b82f6;
    border-radius: 50%;
    position: relative;
    box-shadow: 0 0 10px #3b82f6;
  }

  .pulse-dot::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: inherit;
    border-radius: inherit;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 0.8; }
    70% { transform: scale(4); opacity: 0; }
    100% { transform: scale(4); opacity: 0; }
  }
</style>
