---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import SignalCard from '../components/SignalCard.astro';
import MirrorStage from '../components/MirrorStage.astro';
import { getSortedSignals } from '../db-local/sorting';

// Lightning-Fast Feed Logic: SSR the first 50 results immediately.
let initialSignals = [];
try {
  initialSignals = await getSortedSignals(50);
  // [Snap-Fast] Edge Caching: Cache the entire SSR output for 15s
  Astro.response.headers.set('Cache-Control', 'public, max-age=15, s-max-age=15');
} catch (err) {
  console.error("[index] Feed error:", err);
}
---

<Layout title="Feed | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-16">
      <div class="flex items-center gap-2 mb-6 group cursor-default">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blueberry-500 tracking-[0.2em] uppercase transition-all group-hover:tracking-[0.4em]">LIVE SIGNAL FEED</span>
      </div>
      
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 mb-12">
        <div class="max-w-2xl">
          <h1 class="text-4xl sm:text-6xl font-black text-blueberry-900 mb-6 leading-[0.9] tracking-tighter uppercase whitespace-pre-line">
            Live Signals. Automated Capture. 
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-500">Your Next Job, Found.</span>
          </h1>
          <p class="text-lg text-blueberry-800/70 font-medium leading-relaxed max-w-xl">
            Stop chasing every lead and start winning the right ones. Our engine surgically sifts through global opportunities, purging tech noise and executive roles to prioritize accessible VA and non-tech positions for Filipinos.
          </p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="relative w-full sm:max-w-md group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blueberry-800/40 group-focus-within:text-blueberry-500 transition-colors"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          </div>
          <input 
            type="text" 
            id="oppSearch" 
            placeholder="Search roles or companies..." 
            class="bg-[#FDFBF7] border-2 border-oat-200/50 rounded-2xl pl-12 pr-6 py-4 text-sm text-blueberry-900 focus:outline-none focus:border-oat-200 focus:bg-white backdrop-blur-xl transition-all font-medium placeholder:text-blueberry-800/40 w-full shadow-sm hover:shadow-md"
          />
        </div>
        <div class="flex items-center gap-1.5 p-1 bg-[#FDFBF7] border-2 border-oat-200/50 rounded-2xl shadow-sm overflow-hidden shrink-0" id="timeFilters">
          <button data-filter="all" class="time-btn active">All</button>
          <button data-filter="24" class="time-btn text-emerald-600">24h</button>
          <button data-filter="72" class="time-btn">3d</button>
        </div>
      </div>
    </header>

    <MirrorStage />

    <div 
      class="grid grid-cols-1 gap-3" 
      id="oppsGrid"
      hx-get="/api/control/feed"
      hx-trigger="every 60s"
      hx-swap="innerHTML"
    >
      {initialSignals.map((sig) => (
        <SignalCard signal={sig} />
      ))}
    </div>

    <div id="emptyState" class="hidden py-40 text-center text-blueberry-800/30 font-black uppercase tracking-widest text-sm italic">
      No matching signals found.
    </div>
  </main>
</Layout>

<script is:inline>
  function initFeed() {
    const search = document.getElementById('oppSearch');
    const filters = document.getElementById('timeFilters');
    const grid = document.getElementById('oppsGrid');
    const empty = document.getElementById('emptyState');
    if (!grid) return;

    // Pre-cache item and metadata for extreme search speed
    let items = Array.from(grid.querySelectorAll('.opp-item')).map(el => ({
      el,
      text: el.dataset.search || "",
      age: parseFloat(el.dataset.age || "999")
    }));

    const btns = filters?.querySelectorAll('.time-btn');
    let q = "";
    let limit = Infinity;
    let debounceTimer;

    function run() {
      let count = 0;
      // High-performance loop
      for (let i = 0; i < items.length; i++) {
        const item = items[i];
        const match = item.text.includes(q) && item.age <= limit;
        // Batching DOM updates
        item.el.style.display = match ? 'flex' : 'none';
        if (match) count++;
      }
      if (empty) empty.style.display = count > 0 ? 'none' : 'block';
    }

    search?.addEventListener('input', (e) => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        q = e.target.value.toLowerCase().trim();
        run();
      }, 50); // Minimal debounce for snappy feel
    });

    btns?.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const val = btn.dataset.filter;
        limit = val === 'all' ? Infinity : parseFloat(val);
        run();
      });
    });

    document.addEventListener('htmx:afterSwap', (e) => {
      if (e.detail.target.id === 'oppsGrid') {
        // Refresh cache on HTMX swap
        items = Array.from(grid.querySelectorAll('.opp-item')).map(el => ({
          el,
          text: el.dataset.search || "",
          age: parseFloat(el.dataset.age || "999")
        }));
        run();
      }
    });
  }

  // Use DOMContentLoaded to ensure elements are ready
  document.addEventListener('DOMContentLoaded', initFeed);
  // Also run immediately if script is loaded late
  initFeed();
</script>

<style>
  .time-btn {
    @apply px-6 py-2.5 rounded-xl text-[10px] font-bold uppercase tracking-widest transition-all cursor-pointer text-blueberry-800/40 hover:text-blueberry-900;
  }
  .time-btn.active {
    @apply bg-oat-100 text-blueberry-900 shadow-inner;
  }
</style>
