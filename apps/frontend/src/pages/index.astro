---
import Layout from '../layouts/Layout.astro';
import { db } from '@va-hub/db/client';
import { opportunities as opportunitiesTable } from '@va-hub/db/schema';
import { desc, asc, and, not, eq } from 'drizzle-orm';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'max-age=0, s-maxage=60, stale-while-revalidate=59');

let liveOpportunities = [];
let dbError = null;

try {
  liveOpportunities = await db.select()
    .from(opportunitiesTable)
    .where(not(eq(opportunitiesTable.tier, 4)))
    .orderBy(asc(opportunitiesTable.tier), desc(opportunitiesTable.scrapedAt))
    .limit(1000); 
} catch (e) {
  dbError = e.message;
}

function formatRelativeTime(dateInput: Date | null) {
  if (!dateInput) return 'Just Now';
  const now = new Date();
  const date = new Date(dateInput);
  const diffMs = now.getTime() - date.getTime();
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  
  if (diffMs < 3600000) return 'Just Now'; // < 1 hour
  if (diffHours < 24) return `${diffHours}h ago`;
  
  const diffDays = Math.floor(diffHours / 24);
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays}d ago`;
  
  return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
}

const PH_FRIENDLY_COMPANIES = ["virtualstaff", "onlinejobs", "remote staff", "bruntwork", "athena", "cyberbacker", "outsourced", "filta"];

function getTier(opp: any) {
  const title = (opp.title || "").toLowerCase();
  const company = (opp.company || "").toLowerCase();
  const desc = (opp.description || "").toLowerCase();
  const source = (opp.sourcePlatform || "").toLowerCase();
  const text = `${title} ${company} ${desc} ${source}`.toLowerCase();
  
  // 0. HARD KILLS (TRASH TIER)
  const strictKills = [
    "strictly us", "usa only", "us only", "americas only", "citizens only", 
    "uk only", "united kingdom only", "canada only", "europe only", "china only",
    "u.s. cities", "united states only", "us based", "usa based"
  ];
  const regionalKills = [
    "beijing", "shanghai", "tokyo", "london", "paris", "berlin", "moscow", "riyadh",
    "dubai", "new york", "san francisco", "chicago", "hong kong", "singapore",
    "china", "europe", "emea", "latam"
  ];

  if (strictKills.some(k => text.includes(k) && !text.includes("philippines"))) return 4;
  if (regionalKills.some(k => text.includes(k) && !text.includes("philippines") && !text.includes("remote") && !text.includes("global"))) return 4;

  const techSenior = ["senior", "lead", "principal", "staff engineer", "architect", "manager", "vp", "director", "head of cloud", "cloud alliances"];
  if (techSenior.some(s => title.includes(s)) && !text.includes("philippines")) return 4;

  // 1. Tech & Corporate Neutralization (Prevents tech/corporate infiltration into Gold)
  const highEndTech = ["engineer", "developer", "software", "devops", "sre", "data scientist", "programmer", "architect", "fullstack", "backend", "frontend", "coder", "systems"];
  const isHighEndTech = highEndTech.some(ht => title.includes(ht)) && !text.includes("junior") && !text.includes("entry");
  
  const corporateNoise = ["analyst", "manager", "executive", "specialist", "counsel", "payroll", "recruiter", "strategist", "consultant", "account executive", "legal", "compliance"];
  const isCorporateNoise = corporateNoise.some(cn => title.includes(cn)) && !title.includes("assistant") && !title.includes("support");

  if (source.includes("hackernews") || source.includes("hiring.cafe")) {
    return isHighEndTech || isCorporateNoise ? 3 : 2;
  }

  // 2. Accessibility & PH-Native (The True Gold)
  const phSignals = ["philippines", "filipino", "pinoy", "tagalog", "remote ph"];
  const vaSignals = ["virtual assistant", "va", "data entry", "bookkeeping", "executive assistant", "admin assistant", "customer service", "customer support", "moderator", "transcription", "clerk", "receptionist"];
  
  if (phSignals.some(s => text.includes(s)) || vaSignals.some(r => title.includes(r))) {
     if (isHighEndTech || isCorporateNoise) return 2; // Tech/Corp mixed with VA signals is Silver
     return 1;
  }
  if (PH_FRIENDLY_COMPANIES.some(c => company.includes(c))) return 1;

  // 3. Source Elevation (Secondary Gold / Silver)
  const prioritySources = ["reddit", "brave", "upwork", "hubstaff"];
  if (prioritySources.some(s => source.includes(s))) {
    if (isHighEndTech || isCorporateNoise) return 2;
    return 1; // High-fidelity community role (non-tech/corp) is Gold
  }

  if (isHighEndTech || isCorporateNoise) return 3; // Corporate/Tech from generic source is Bronze

  // 4. SILVER TIER (Global Remote / Non-Techy)
  const accessibilitySignals = ["assistant", "marketing", "social media", "support", "sales", "entry level", "no experience"];
  const globalSignals = ["worldwide", "global", "anywhere", "remote"];
  if (globalSignals.some(g => text.includes(g)) && accessibilitySignals.some(a => title.includes(a))) return 2;

  // 5. BRONZE TIER (Everything Else)
  return 3;
}

function getFreshnessScore(opp: any) {
  const now = Date.now();
  const scrapedAt = new Date(opp.scrapedAt).getTime();
  const ageHrs = (now - scrapedAt) / (1000 * 60 * 60);
  
  if (ageHrs < 1) return 1000000;
  if (ageHrs < 4) return 500000;
  if (ageHrs < 24) return 100000;
  return 50000;
}

// 1. Tier & Score & Initial Sort
const scored = liveOpportunities.map(opp => ({
  ...opp,
  tier: getTier(opp),
  freshnessScore: getFreshnessScore(opp),
  relevancyScore: (4 - getTier(opp)) * 1000000 + getFreshnessScore(opp)
})).sort((a, b) => {
  if (a.tier !== b.tier) return a.tier - b.tier; // Lower tier (1) wins
  return b.freshnessScore - a.freshnessScore; // Newer wins within tier
});

// 2. Fuzzy Dedup & Company Diversity
const seenFingerprints = new Set();
const companyUsage = new Map();
const finalFeed = [];

for (const opp of scored) {
  const normTitle = opp.title.toLowerCase().replace(/[^a-z0-9]/g, '').slice(0, 30);
  const normCompany = (opp.company || 'unknown').toLowerCase().trim();
  const fingerprint = `${normTitle}|${normCompany}`;
  
  if (seenFingerprints.has(fingerprint)) continue;

  // Dynamic Slot Budget
  const slotLimit = opp.tier === 1 ? 3 : 1;
  const currentUsage = companyUsage.get(normCompany) || 0;

  if (currentUsage < slotLimit) {
    seenFingerprints.add(fingerprint);
    companyUsage.set(normCompany, currentUsage + 1);
    
    // Final UI Prep
    const latestDate = new Date(Math.max(new Date(opp.postedAt || 0).getTime(), new Date(opp.scrapedAt).getTime()));
    const ageHrs = (Date.now() - latestDate.getTime()) / (1000 * 60 * 60);

    finalFeed.push({
      ...opp,
      displayDate: formatRelativeTime(latestDate),
      ageHrs
    });
  }

  if (finalFeed.length >= 200) break;
}
---

<Layout title="Feed | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-16">
      <div class="flex items-center gap-2 mb-6 group cursor-default">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blueberry-500 tracking-[0.2em] uppercase transition-all group-hover:tracking-[0.4em]">LIVE SIGNAL FEED</span>
      </div>
      
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 mb-12">
        <div class="max-w-2xl">
          <h1 class="text-4xl sm:text-6xl font-black text-blueberry-900 mb-6 leading-[0.9] tracking-tighter uppercase whitespace-pre-line">
            Live Signals. Automated Capture. 
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-500">Your Next Job, Found.</span>
          </h1>
          <p class="text-lg text-blueberry-800/70 font-medium leading-relaxed max-w-xl">
            Stop chasing every lead and start winning the right ones. Our engine sifts through thousands of global opportunities every hour, filtering out the noise to prioritize the roles where Filipinos are already the top choice.
          </p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="relative w-full sm:max-w-md group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blueberry-800/40 group-focus-within:text-blueberry-500 transition-colors"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          </div>
          <input 
            type="text" 
            id="oppSearch" 
            placeholder="Search roles or companies..." 
            class="bg-white/80 border border-blueberry-800/10 rounded-3xl pl-12 pr-6 py-4 text-sm text-blueberry-900 focus:outline-none focus:border-blueberry-500/40 focus:bg-white backdrop-blur-xl transition-all font-medium placeholder:text-blueberry-800/40 w-full shadow-sm"
          />
        </div>
        <div class="flex items-center gap-1.5 p-1 bg-white border border-blueberry-800/10 rounded-3xl shadow-sm overflow-hidden shrink-0" id="timeFilters">
          <button data-filter="all" class="time-btn active">All</button>
          <button data-filter="24" class="time-btn text-emerald-600">24h</button>
          <button data-filter="72" class="time-btn">3d</button>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 gap-3" id="oppsGrid">
      {finalFeed.map((opp) => (
        <a 
          href={opp.sourceUrl} 
          target="_blank" 
          class="opp-item flex flex-col sm:flex-row sm:items-center justify-between p-5 sm:p-6 rounded-[2rem] sm:rounded-[2.5rem] bg-white border border-blueberry-800/5 hover:border-blueberry-500/20 hover:shadow-xl transition-all group relative active:scale-[0.99] shadow-sm gap-4"
          data-search={`${opp.title} ${opp.company}`.toLowerCase()}
          data-age={opp.ageHrs}
        >
          <div class="flex items-center gap-4 sm:gap-6">
            <div class="flex sm:flex-col items-center gap-2 sm:gap-0 sm:w-20">
              <span class="text-[10px] font-black text-blueberry-800/40 uppercase tracking-tighter">{opp.displayDate}</span>
              {opp.ageHrs < 1 ? (
                <span class="px-2 py-0.5 bg-emerald-500 text-white text-[8px] font-black uppercase rounded-lg shadow-sm shrink-0">Just Now</span>
              ) : opp.ageHrs < 24 ? (
                <span class="px-2 py-0.5 bg-blueberry-50 text-blueberry-500 text-[8px] font-black uppercase rounded-lg border border-blueberry-500/10 shrink-0">Recent</span>
              ) : null}
            </div>
            <div class="h-10 w-[1px] bg-blueberry-800/5 hidden sm:block"></div>
            <div class="min-w-0 flex-1">
              <h3 class="text-[15px] font-black text-blueberry-900 group-hover:text-blueberry-500 transition-colors leading-tight mb-1 uppercase tracking-tight break-words">{opp.title}</h3>
              <div class="flex items-center gap-2">
                <span class="text-[10px] text-blueberry-800/60 font-bold uppercase tracking-widest truncate">{opp.company}</span>
                {opp.relevancyScore > 1000000 && <span class="text-[10px]">🔥</span>}
              </div>
            </div>
          </div>
          <div class="flex items-center justify-between sm:justify-end gap-4 text-blueberry-800/20">
             <span class="text-[9px] font-black uppercase tracking-[0.2em]">{opp.sourcePlatform}</span>
             <div class="w-10 h-10 rounded-full bg-blueberry-50 flex items-center justify-center opacity-0 group-hover:opacity-100 sm:opacity-0 transition-all scale-75 group-hover:scale-100">
               <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blueberry-500"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
             </div>
          </div>
        </a>
      ))}
    </div>

    <div id="emptyState" class="hidden py-40 text-center text-blueberry-800/30 font-black uppercase tracking-widest text-sm italic">
      No matching signals found.
    </div>
  </main>
</Layout>

<script is:inline>
  function initFeed() {
    const search = document.getElementById('oppSearch');
    const filters = document.getElementById('timeFilters');
    const grid = document.getElementById('oppsGrid');
    const empty = document.getElementById('emptyState');
    if (!grid) return;

    const items = grid.querySelectorAll('.opp-item');
    const btns = filters?.querySelectorAll('.time-btn');
    let q = "";
    let limit = Infinity;

    function run() {
      let count = 0;
      items.forEach(el => {
        const text = el.dataset.search || "";
        const age = parseFloat(el.dataset.age || "999");
        const match = text.includes(q) && age <= limit;
        el.style.display = match ? 'flex' : 'none';
        if (match) count++;
      });
      if (empty) empty.style.display = count > 0 ? 'none' : 'block';
    }

    search?.addEventListener('input', (e) => {
      q = e.target.value.toLowerCase().trim();
      run();
    });

    btns?.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const val = btn.dataset.filter;
        limit = val === 'all' ? Infinity : parseFloat(val);
        run();
      });
    });

    run();
  }

  if (!window._feedInitSet) {
    document.addEventListener('astro:after-swap', initFeed);
    window._feedInitSet = true;
  }
  initFeed();
</script>

<style>
  .time-btn {
    @apply px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all cursor-pointer text-blueberry-800/40 hover:text-blueberry-900;
  }
  .time-btn.active {
    @apply bg-blueberry-50 text-blueberry-900 shadow-inner;
  }
  .opp-item {
    box-shadow: 0 4px 20px -10px rgba(40, 53, 147, 0.05);
  }
</style>
