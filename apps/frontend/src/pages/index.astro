---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { db, sql } from '@va-hub/db';
import { opportunities } from '@va-hub/db/schema';
import { desc, asc, eq, not, gt, gte, and, or, count } from 'drizzle-orm';

// 1. Edge-Side Caching (SWR: 60s fresh, 30s stale)
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=30');

// 2. Aggregate Purity Distribution

let liveOpportunities = [];
let dbError = null;

try {
  // Ultra-Fast Indexed Sort using tier_latest_idx
  liveOpportunities = await db.select()
    .from(opportunities)
    .where(not(eq(opportunities.tier, 4)))
    .orderBy(
      asc(opportunities.tier),
      desc(opportunities.latestActivityMs)
    )
    .limit(150); 
} catch (e) {
  dbError = e.message;
}

function formatRelativeTime(dateInput: Date | null) {
  if (!dateInput) return 'Just Now';
  const now = new Date();
  const date = new Date(dateInput);
  const diffMs = now.getTime() - date.getTime();
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  
  if (diffMs < 3600000) return 'Just Now'; // < 1 hour
  if (diffHours < 24) return `${diffHours}h ago`;
  
  const diffDays = Math.floor(diffHours / 24);
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays}d ago`;
  
  return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
}

// Trust the tier from the DB (Purity-Certified by Native Sifter)
function getTier(opp: any) {
  return opp.tier;
}

// 2. Final Output Formatting (Dedup offloaded to DB)
const finalFeed = liveOpportunities.map(opp => {
  const ageHrs = (Date.now() - opp.latestDateMs) / (1000 * 60 * 60);
  return {
    ...opp,
    ageHrs,
    displayDate: formatRelativeTime(new Date(opp.latestDateMs))
  };
});
---

<Layout title="Feed | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-16">
      <div class="flex items-center gap-2 mb-6 group cursor-default">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blueberry-500 tracking-[0.2em] uppercase transition-all group-hover:tracking-[0.4em]">LIVE SIGNAL FEED</span>
      </div>
      
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 mb-12">
        <div class="max-w-2xl">
          <h1 class="text-4xl sm:text-6xl font-black text-blueberry-900 mb-6 leading-[0.9] tracking-tighter uppercase whitespace-pre-line">
            Live Signals. Automated Capture. 
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-500">Your Next Job, Found.</span>
          </h1>
          <p class="text-lg text-blueberry-800/70 font-medium leading-relaxed max-w-xl">
            Stop chasing every lead and start winning the right ones. Our engine surgically sifts through global opportunities, purging tech noise and executive roles to prioritize accessible VA and non-tech positions for Filipinos.
          </p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="relative w-full sm:max-w-md group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blueberry-800/40 group-focus-within:text-blueberry-500 transition-colors"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          </div>
          <input 
            type="text" 
            id="oppSearch" 
            placeholder="Search roles or companies..." 
            class="bg-[#FDFBF7] border-2 border-oat-200/50 rounded-2xl pl-12 pr-6 py-4 text-sm text-blueberry-900 focus:outline-none focus:border-oat-200 focus:bg-white backdrop-blur-xl transition-all font-medium placeholder:text-blueberry-800/40 w-full shadow-sm hover:shadow-md"
          />
        </div>
        <div class="flex items-center gap-1.5 p-1 bg-[#FDFBF7] border-2 border-oat-200/50 rounded-2xl shadow-sm overflow-hidden shrink-0" id="timeFilters">
          <button data-filter="all" class="time-btn active">All</button>
          <button data-filter="24" class="time-btn text-emerald-600">24h</button>
          <button data-filter="72" class="time-btn">3d</button>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 gap-3" id="oppsGrid">
      {finalFeed.map((opp) => (
        <a 
          href={opp.sourceUrl} 
          target="_blank" 
          class="opp-item flex flex-col sm:flex-row sm:items-center justify-between p-5 sm:p-5 rounded-2xl bg-[#FDFBF7] border-2 border-oat-200/50 hover:border-oat-200 hover:shadow-md transition-all group relative active:scale-[0.98] shadow-sm gap-4"
          data-search={`${opp.title} ${opp.company}`.toLowerCase()}
          data-age={opp.ageHrs}
        >
          <div class="flex items-center gap-4 sm:gap-6">
            <div class="flex sm:flex-col items-center gap-2 sm:gap-0 sm:w-20">
              <span class="text-[10px] font-black text-blueberry-800/40 uppercase tracking-tighter">{opp.displayDate}</span>
              {opp.ageHrs < 0.25 ? (
                <span class="px-2 py-0.5 bg-emerald-500 text-white text-[8px] font-black uppercase rounded-lg shadow-sm shrink-0">15m New</span>
              ) : opp.ageHrs < 24 ? (
                <span class="px-2 py-0.5 bg-oat-100 text-blueberry-500 text-[8px] font-black uppercase rounded-lg border border-oat-200 shrink-0">Recent</span>
              ) : null}
            </div>
            <div class="h-10 w-[1px] bg-oat-200/50 hidden sm:block"></div>
            <div class="min-w-0 flex-1">
              <h3 class="text-[15px] font-bold text-blueberry-900/90 group-hover:text-blueberry-600 transition-colors leading-tight mb-0.5 uppercase tracking-tight break-words">{opp.title}</h3>
              <div class="flex items-center gap-2">
                <span class="text-[10px] text-blueberry-800/60 font-bold uppercase tracking-widest truncate">{opp.company}</span>
                {opp.effectiveTier < 0 && <span class="text-[10px]">🔥</span>}
              </div>
            </div>
          </div>
          <div class="flex items-center justify-between sm:justify-end gap-4 text-blueberry-800/20">
             <span class="text-[9px] font-black uppercase tracking-[0.2em]">{opp.sourcePlatform}</span>
             <div class="w-10 h-10 rounded-full bg-oat-100 flex items-center justify-center opacity-0 group-hover:opacity-100 sm:opacity-0 transition-all scale-75 group-hover:scale-100">
               <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blueberry-500"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
             </div>
          </div>
        </a>
      ))}
    </div>

    <div id="emptyState" class="hidden py-40 text-center text-blueberry-800/30 font-black uppercase tracking-widest text-sm italic">
      No matching signals found.
    </div>
  </main>
</Layout>

<script is:inline>
  function initFeed() {
    const search = document.getElementById('oppSearch');
    const filters = document.getElementById('timeFilters');
    const grid = document.getElementById('oppsGrid');
    const empty = document.getElementById('emptyState');
    if (!grid) return;

    const items = grid.querySelectorAll('.opp-item');
    const btns = filters?.querySelectorAll('.time-btn');
    let q = "";
    let limit = Infinity;

    function run() {
      let count = 0;
      items.forEach(el => {
        const text = el.dataset.search || "";
        const age = parseFloat(el.dataset.age || "999");
        const match = text.includes(q) && age <= limit;
        el.style.display = match ? 'flex' : 'none';
        if (match) count++;
      });
      if (empty) empty.style.display = count > 0 ? 'none' : 'block';
    }

    search?.addEventListener('input', (e) => {
      q = e.target.value.toLowerCase().trim();
      run();
    });

    btns?.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const val = btn.dataset.filter;
        limit = val === 'all' ? Infinity : parseFloat(val);
        run();
      });
    });

    run();
  }

  if (!window._feedInitSet) {
    document.addEventListener('astro:after-swap', initFeed);
    window._feedInitSet = true;
  }
  initFeed();
</script>

<style>
  .time-btn {
    @apply px-6 py-2.5 rounded-xl text-[10px] font-bold uppercase tracking-widest transition-all cursor-pointer text-blueberry-800/40 hover:text-blueberry-900;
  }
  .time-btn.active {
    @apply bg-oat-100 text-blueberry-900 shadow-inner;
  }
</style>
