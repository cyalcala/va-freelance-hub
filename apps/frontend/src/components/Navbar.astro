---
const currentPath = Astro.url.pathname;
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-black/50 backdrop-blur-xl border-b border-white/10">
  <div class="max-w-[1400px] mx-auto px-8 h-20 flex items-center justify-between">
    <div class="flex items-center gap-8">
      <a href="/" class="text-white font-black text-xl tracking-tighter hover:text-blue-500 transition-colors">
        VA.INDEX
      </a>
      <div class="h-6 w-[1px] bg-white/10"></div>
      <div class="flex items-center gap-6">
        <a 
          href="/" 
          class={`text-sm font-medium transition-colors ${currentPath === '/' ? 'text-blue-500' : 'text-zinc-400 hover:text-white'}`}
        >
          Agencies
        </a>
        <a 
          href="/opportunities" 
          class={`text-sm font-medium transition-colors ${currentPath === '/opportunities' ? 'text-blue-500' : 'text-zinc-400 hover:text-white'}`}
        >
          Opportunities
        </a>
      </div>
    </div>
    
    <div class="flex items-center gap-4">
      <div class="hidden md:flex items-center gap-2 px-3 py-1 bg-blue-500/10 border border-blue-500/20 rounded-full">
        <div class="w-1.5 h-1.5 bg-blue-500 rounded-full animate-pulse"></div>
        <span class="text-[10px] font-bold text-blue-500 tracking-wider">LIVE DATA</span>
      </div>
    </div>
  </div>
</nav>

<style>
  a {
    text-decoration: none;
  }
</style>
