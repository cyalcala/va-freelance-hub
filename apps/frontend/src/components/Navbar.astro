---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const isAgencies = currentPath === '/agencies';
---
<nav class="fixed top-0 left-0 right-0 z-50 border-b border-blueberry-800/10 bg-white/70 backdrop-blur-2xl">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 min-h-[72px] sm:h-20 flex flex-col sm:flex-row items-center justify-center sm:justify-between py-3 sm:py-0 gap-4 sm:gap-0">
    <!-- Primary Logo & Subtitle Group -->
    <div class="flex flex-col items-start group">
      <a href="/" class="flex items-center gap-2 sm:gap-3 hover:scale-[1.01] transition-transform duration-300">
        <!-- Icon (Workbound Scale) -->
        <div class="w-8 h-8 sm:w-10 sm:h-10 bg-blue-600 rounded-full flex items-center justify-center shadow-[0_8px_25px_-8px_rgba(37,99,235,0.5)] group-hover:rotate-6 transition-transform duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="2.5" class="translate-x-0.5 sm:w-5 sm:h-5"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
        </div>
        <!-- Title: VA INDEX (Workbound Boldness) -->
        <span class="text-[24px] sm:text-[32px] tracking-[-0.04em] font-black text-blueberry-900 leading-none uppercase font-heading">VA INDEX</span>
      </a>
      
      <!-- Subtitle Layer (Aligned under icon) -->
      <div class="flex items-center gap-1 sm:gap-2 mt-1 sm:ml-0.5 flex-wrap justify-center sm:justify-start">
        <span class="text-[8px] sm:text-[10px] text-blueberry-400 font-bold uppercase tracking-[0.15em] sm:tracking-[0.18em] whitespace-nowrap leading-none">Real-Time Jobs Directory</span>
        <span class="hidden sm:inline text-[8px] text-blueberry-300 font-black opacity-30 leading-none">•</span>
        <a 
          href="https://www.linkedin.com/in/cyrusalcala/" 
          target="_blank" 
          class="text-[8px] sm:text-[10px] text-blueberry-400/40 font-bold uppercase tracking-[0.15em] sm:tracking-[0.18em] hover:text-blue-600 transition-colors whitespace-nowrap leading-none"
        >
          MADE WITH ❤️ BY CY ALCALA
        </a>
      </div>
    </div>

    <div class="p-1 bg-oat-100/50 border border-oat-200/50 rounded-2xl flex items-center gap-1 shadow-inner relative overflow-hidden shrink-0" transition:name="navbar-tabs">
      <div 
        class={`absolute inset-y-1 rounded-xl bg-white shadow-sm border border-blueberry-800/5 transition-all duration-300 ease-out ${isHome ? 'left-1 w-[calc(50%-4px)]' : 'left-[calc(50%+1px)] w-[calc(50%-4px)]'}`}
        transition:name="active-pill"
      ></div>
      <a 
        href="/" 
        class={`relative z-10 px-4 sm:px-8 py-2 rounded-xl text-[10px] sm:text-[11px] font-bold uppercase tracking-widest transition-all duration-300 w-1/2 text-center ${isHome ? 'text-blueberry-900' : 'text-blueberry-800/40 hover:text-blueberry-900'}`}
      >
        Feed
      </a>
      <a 
        href="/agencies" 
        class={`relative z-10 px-4 sm:px-8 py-2 rounded-xl text-[10px] sm:text-[11px] font-bold uppercase tracking-widest transition-all duration-300 w-1/2 text-center ${isAgencies ? 'text-blueberry-900' : 'text-blueberry-800/40 hover:text-blueberry-900'}`}
      >
        Agencies List
      </a>
    </div>
  </div>
</nav>

<style>
  a { text-decoration: none; }
</style>
