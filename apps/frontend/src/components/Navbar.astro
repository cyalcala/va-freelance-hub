---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const isOpp = currentPath === '/opportunities';
const isAbout = currentPath === '/about';
---
<nav class="fixed top-0 left-0 right-0 z-50 border-b border-blueberry-800/10 bg-oat-50/80 backdrop-blur-2xl">
  <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 text-blueberry-900 font-black text-xs tracking-tighter hover:scale-105 transition-all">
      <div class="w-7 h-7 bg-blueberry-500 rounded-lg flex items-center justify-center font-black text-white text-sm shadow-[0_0_20px_-5px_rgba(63,81,181,0.3)]">V</div>
      <span class="hidden sm:inline">VA.INDEX (V5.2)</span>
    </a>

    <div class="p-1.5 border bg-white border-blueberry-800/10 rounded-2xl flex items-center gap-1 shadow-sm relative overflow-hidden" transition:persist transition:name="navbar-tabs">
      <div 
        class={`absolute inset-y-1.5 rounded-xl bg-oat-50 shadow-sm border border-blueberry-800/5 transition-all duration-200 ease-out ${isHome ? 'left-1.5 w-[calc(50%-6px)]' : 'left-[calc(50%+1.5px)] w-[calc(50%-6px)]'}`}
        transition:name="active-pill"
      ></div>
      <a 
        href="/" 
        data-astro-prefetch
        class={`relative z-10 px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 w-1/2 text-center ${isHome ? 'text-blueberry-900' : 'text-blueberry-800/70 hover:text-blueberry-900'}`}
      >
        Agencies
      </a>
      <a 
        href="/opportunities" 
        data-astro-prefetch
        class={`relative z-10 px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 w-1/2 text-center ${isOpp ? 'text-blueberry-900' : 'text-blueberry-800/70 hover:text-blueberry-900'}`}
      >
        Feed
      </a>
    </div>
    
    <div class="flex items-center gap-6">
      <a href="/about" class={`text-[10px] font-black uppercase tracking-widest transition-all ${isAbout ? 'text-blueberry-500' : 'text-blueberry-800/60 hover:text-blueberry-900'}`}>Mission</a>
      <div class="hidden md:flex items-center gap-2 pr-2">
        <div class="pulse-dot"></div>
        <span class="text-[8px] font-black text-blueberry-500 tracking-[0.2em] uppercase">SYNCING</span>
      </div>
    </div>
  </div>
</nav>

<style>
  a { text-decoration: none; }
</style>
