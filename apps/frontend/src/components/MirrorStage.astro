---
/**
 * MirrorStage.astro
 * An ultra-lightweight, high-velocity "Latest Signals" stage.
 * [Snap-Fast Protocol]: Injects the first 10 signals via SSR for instant view.
 * Uses HTMX to poll for updates thereafter.
 */
import { getLatestMirror } from '../db-local/sorting';
import ThinCard from './ThinCard.astro';

let signals = [];
try {
  signals = await getLatestMirror(10);
  
  // High-Purity Fallback: If DB is empty or cold, provide 3 "Syncing" signals
  if (signals.length === 0) {
    signals = [
      { id: 'fallback-1', title: 'System Synchronizing Core Intelligence...', company: 'APEX SENTINEL', tier: 1, latestActivityMs: Date.now() },
      { id: 'fallback-2', title: 'Calibrating PH-First Signal Decay...', company: 'VA.INDEX', tier: 2, latestActivityMs: Date.now() },
      { id: 'fallback-3', title: 'Harvesting Live Global Opportunities...', company: 'MIRROR ENGINE', tier: 3, latestActivityMs: Date.now() }
    ];
  }
} catch (err) {
  console.error("[MirrorStage] SSR error:", err);
}
---
<div class="mb-12 p-1 bg-white/40 backdrop-blur-md border border-oat-200/40 rounded-3xl shadow-sm overflow-hidden group">
  <div class="flex items-center justify-between px-6 py-3 border-b border-oat-200/30 bg-white/20">
    <div class="flex items-center gap-3">
      <div class="relative flex h-3 w-3">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
      </div>
      <span class="text-[10px] font-black text-blueberry-900 tracking-[0.2em] uppercase transition-all group-hover:tracking-[0.4em]">Hyperflow Mirror</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-[9px] font-bold text-blueberry-800/40 uppercase">streaming 10 freshest signals</span>
    </div>
  </div>
  
  <div 
    class="px-5 py-2 min-h-[100px]"
    hx-get="/api/control/mirror"
    hx-trigger="every 30s"
    hx-swap="innerHTML"
  >
    <div class="flex flex-col w-full divide-y divide-oat-200/30">
      {signals.map((sig: any) => (
        <ThinCard key={`mirror-${sig.id}`} signal={sig} />
      ))}
    </div>
  </div>

  <div class="px-6 py-2 bg-oat-50/30 border-t border-oat-200/20 text-center">
    <span class="text-[8px] font-black text-blueberry-800/20 uppercase tracking-[0.3em]">Titanium-Fast Mirror Engine v1.0</span>
  </div>
</div>
