---
import Navbar from '../components/Navbar.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="bg-oat-50 text-blueberry-900 scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script src="https://unpkg.com/htmx.org@1.9.10"></script>
		<ClientRouter />
	</head>
	<body class="selection:bg-blueberry-100 selection:text-blueberry-900 font-['Geist',sans-serif] bg-oat-50 antialiased overflow-x-hidden min-h-screen">
		<Navbar />
		<div class="relative pt-20">
			<slot />
		</div>

		<style is:global>
			::-webkit-scrollbar {
				width: 8px;
			}
			::-webkit-scrollbar-track {
				background: #FDFBF7;
			}
			::-webkit-scrollbar-thumb {
				background: #C5CAE9;
				border: 2px solid #FDFBF7;
				border-radius: 10px;
			}
			::-webkit-scrollbar-thumb:hover {
				background: #5C6BC0;
			}
		</style>
	</body>
</html>
