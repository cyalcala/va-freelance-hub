---
import Navbar from '../components/Navbar.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="bg-oat-50 text-blueberry-900 scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="selection:bg-blueberry-100 selection:text-blueberry-900 font-['Geist',sans-serif] bg-oat-50 antialiased overflow-x-hidden min-h-screen">
		<Navbar />
		<div class="relative pt-20">
			<slot />
		</div>

		<script is:inline>
			// VA.INDEX IMMORTAL INTERACTION ENGINE (V3)
			(function() {
				window.__VA_STATE = window.__VA_STATE || { q: "", age: "all", activeOnly: false };

				function syncUI() {
					const path = window.location.pathname;
					const isFeed = path.includes('/opportunities');
					const isAgencies = path === '/' || path === '';

					// Sync Search Input Value
					const search = document.getElementById('oppSearch') || document.getElementById('agencySearch');
					if (search) search.value = window.__VA_STATE.q || "";

					if (isFeed) {
						const grid = document.getElementById('oppsGrid');
						const empty = document.getElementById('oppsEmpty');
						if (!grid) return;
						const items = grid.querySelectorAll('.opp-card');
						let visible = 0;
						items.forEach(el => {
							const text = el.dataset.search || "";
							const hours = parseFloat(el.dataset.age || "999");
							const match = text.includes(window.__VA_STATE.q) && 
														(window.__VA_STATE.age === "all" || hours <= parseFloat(window.__VA_STATE.age));
							el.style.display = match ? 'flex' : 'none';
							if (match) visible++;
						});
						if (empty) empty.style.display = visible > 0 ? 'none' : 'block';
					}

					if (isAgencies) {
						const grid = document.getElementById('agenciesGrid');
						const empty = document.getElementById('agenciesEmpty');
						if (!grid) return;
						const cards = grid.querySelectorAll('.glass-card');
						let visible = 0;
						cards.forEach(el => {
							const name = el.dataset.name || "";
							const status = el.dataset.status || "";
							const match = name.includes(window.__VA_STATE.q) && 
														(!window.__VA_STATE.activeOnly || status === 'active');
							el.style.display = match ? 'flex' : 'none';
							if (match) visible++;
						});
						if (empty) empty.style.display = visible > 0 ? 'none' : 'block';
					}
				}

				if (!window.__VA_CORE_INIT) {
					document.addEventListener('input', (e) => {
						if (e.target.id === 'oppSearch' || e.target.id === 'agencySearch') {
							window.__VA_STATE.q = e.target.value.toLowerCase().trim();
							syncUI();
						}
					});

					document.addEventListener('click', (e) => {
						const ageBtn = e.target.closest('[data-age]');
						if (ageBtn) {
							const container = ageBtn.closest('#oppFilters');
							if (container) {
								container.querySelectorAll('.time-btn').forEach(b => b.classList.remove('active'));
								ageBtn.classList.add('active');
								window.__VA_STATE.age = ageBtn.dataset.age;
								syncUI();
							}
						}

						const hireBtn = e.target.closest('[data-toggle-hiring]');
						if (hireBtn) {
							window.__VA_STATE.activeOnly = !window.__VA_STATE.activeOnly;
							hireBtn.classList.toggle('active-filter', window.__VA_STATE.activeOnly);
							hireBtn.innerText = window.__VA_STATE.activeOnly ? '✓ Showing Hiring' : 'Hiring Now Only';
							syncUI();
						}
					});
					window.__VA_CORE_INIT = true;
				}

				document.addEventListener('astro:page-load', syncUI);
				syncUI();
			})();
		</script>

		<style is:global>

			::-webkit-scrollbar {
				width: 8px;
			}
			::-webkit-scrollbar-track {
				background: #FDFBF7;
			}
			::-webkit-scrollbar-thumb {
				background: #C5CAE9;
				border: 2px solid #FDFBF7;
				border-radius: 10px;
			}
			::-webkit-scrollbar-thumb:hover {
				background: #5C6BC0;
			}
		</style>
	</body>
</html>
